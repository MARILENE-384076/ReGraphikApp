<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    WindowStartupLocation="CenterScreen"
    Background="#F3F4F6">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#2563EB">

            <StackPanel>

                <TextBlock
                    Text="ReGraphik"
                    Foreground="White"
                    FontSize="28"
                    FontWeight="Bold"
                    Margin="20"/>

                <Button
                    Content="Dashboard"
                    Height="45"
                    Margin="10,5"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Dashboard_Click"/>

                <Button
                    Content="Cadastrar Resíduos"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Residuos_Click"/>

                <Button
                    Content="Pontos de Coleta"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Pontos_Click"/>

                <Button
                    Content="Mapa"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Mapa_Click"/>

                <Button
                    Content="Relatórios"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Relatorios_Click"/>

            </StackPanel>

        </Border>

        <Grid Grid.Column="1"
              Margin="20">

            <Grid x:Name="DashboardGrid">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Dashboard"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <Grid
                x:Name="ResiduosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Cadastrar Resíduos"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <Grid
                x:Name="PontosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Pontos de Coleta"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <Grid
                x:Name="MapaGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <Grid Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Localizar Coleta" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15"/>

                            <TextBlock Text="Cidade / Região:" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtCidadeBusca" Text="Belo Horizonte" Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                            <TextBlock Text="Material Gráfico:" FontSize="14" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CboMaterialBusca" Height="35" Margin="0,0,0,20" SelectedIndex="0" FontSize="14">
                                <ComboBoxItem Content="Ecoponto Geral (Reciclagem)"/>
                                <ComboBoxItem Content="Aparas de Papel e Papelão"/>
                                <ComboBoxItem Content="Sucata de Alumínio (Chapas CTP)"/>
                                <ComboBoxItem Content="Lixo Eletrônico / Cartuchos"/>
                            </ComboBox>

                            <Button Content="Buscar Pontos Online" 
                                    Height="40" 
                                    Background="#2563EB" 
                                    Foreground="White" 
                                    FontWeight="Bold" 
                                    FontSize="14"
                                    BorderBrush="{x:Null}"
                                    Click="BtnBuscarMapa_Click"/>
                        </StackPanel>

                        <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
                            <wv2:WebView2 x:Name="NavegadorMapa"/>
                        </Border>
                    </Grid>

                </Border>

            </Grid>

            <Grid
                x:Name="RelatoriosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Relatórios"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>