<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" 
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:converters="clr-namespace:ReGraphik.Converters"
    xmlns:uc="clr-namespace:ReGraphik.Views.Controls"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    MinHeight="600"
    MinWidth="960"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    Background="#F3F4F6"
    Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:NaoLidasVisibilidadeConverter x:Key="NaoLidasVisConv"/>
            <converters:BadgeNotificacaoConverter x:Key="BadgeConv"/>
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3274ba" Offset="0.0"/>
                    <GradientStop Color="#1649a2" Offset="0.5"/>
                    <GradientStop Color="#1E40AF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Grid Margin="14,18,14,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="15*"/>
                            <ColumnDefinition Width="143*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Grid.ColumnSpan="2">
                            <iconPacks:PackIconMaterial Kind="Recycle" Foreground="White" Height="35" Width="37" Margin="1,0,0,0"/>
                            <TextBlock Text="REGRAPHIK" Foreground="White" FontWeight="Bold" FontSize="20"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Command="{Binding ChatCommand}"
                                ToolTip="Mensagens"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <iconPacks:PackIconMaterial Kind="MessageTextOutline"
                                                                         Width="22" Height="22"
                                                                         Foreground="White"/>
                                            <Border Background="#1D4ED8"
                                                    CornerRadius="9"
                                                    MinWidth="18" Height="18"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-6,-6,0"
                                                    Padding="3,0"
                                                    Visibility="{Binding ChatViewModel.TemMensagensNaoLidas, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding ChatViewModel.TotalNaoLidas, Converter={StaticResource BadgeConv}}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1">

                    <!-- Dashboard -->
                    <Button x:Name="BtnDashboard"
                            Command="{Binding NavegarDashboardCommand}" Tag="Dashboard"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Dashboard">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para o Dashboard" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Cadastrar Resíduos -->
                    <Button x:Name="BtnResiduos"
                            Command="{Binding NavegarResiduosCommand}" Tag="Residuos"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Residuos">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Cadastrar Resíduos" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePlusOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Cadastrar Resíduos" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Estoque Reverso -->
                    <Button x:Name="BtnEstoqueReverso"
                            Command="{Binding NavegarEstoqueCommand}" Tag="Estoque"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Estoque">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Estoque Reverso" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Warehouse" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Estoque Reverso" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Mapa -->
                    <Button x:Name="BtnMapa"
                            Command="{Binding NavegarMapaCommand}" Tag="Mapa"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Mapa">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Mapa dos pontos de coleta" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapMarkerOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Mapa" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Relatórios -->
                    <Button x:Name="BtnRelatorios"
                            Command="{Binding NavegarRelatoriosCommand}" Tag="Relatorios"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Relatorios">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Relatórios" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Relatórios" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- ESG / Certificação -->
                    <Button x:Name="BtnEsg"
                            Command="{Binding NavegarEsgCommand}" Tag="Esg"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Esg">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Proposta de Valor ESG e Certificação" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Leaf" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="ESG / Certificação" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <StackPanel Grid.Row="2" Margin="8,0,8,12">
                    <TextBlock Text="CONFIGURAÇÕES" FontSize="11" FontWeight="SemiBold" Foreground="#a9bcd2" Margin="20,16,20,8"/>

                    <!-- Minha Conta -->
                    <Button x:Name="BtnConta"
                            Command="{Binding NavegarContaCommand}" Tag="Conta"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavBtn}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BtnAtivo}" Value="Conta">
                                        <Setter Property="Background" Value="#022654"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de modificações da conta" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountCogOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Minha Conta" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Border BorderThickness="0,1,0,0" BorderBrush="#1D4ED8" Margin="0,8,0,8"/>

                    <!-- Sair -->
                    <Button x:Name="BtnSair"
                            Style="{StaticResource NavBtnSair}"
                            Command="{Binding SairCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para sair da aplicação" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Sair" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentView}"
                        Grid.Column="1"
                        Margin="20"/>
    </Grid>
</Window>