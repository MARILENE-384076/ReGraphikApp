<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" 
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:converters="clr-namespace:ReGraphik.Converters"
    xmlns:uc="clr-namespace:ReGraphik.Views.UserControls"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    MinHeight="600"
    MinWidth="960"
    WindowStartupLocation="CenterScreen"
    Background="#F3F4F6"
    Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:NaoLidasVisibilidadeConverter x:Key="NaoLidasVisConv"/>
            <converters:BadgeNotificacaoConverter x:Key="BadgeConv"/>
            <BooleanToVisibilityConverter x:Key="BoolVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#093e75">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <Grid Margin="14,18,14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Título do app -->
                        <TextBlock Grid.Column="0"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                            <TextBlock.Inlines>
                                <iconPacks:PackIconMaterial Kind="Recycle" Height="19" VerticalAlignment="Center" Width="22"/>
                                <Run Text=" ReGraphik"/>
                            </TextBlock.Inlines>
                        </TextBlock>

                        <Button Grid.Column="1"
                                    Command="{Binding ChatCommand }"
                                    ToolTip="Mensagens"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6"
                                    VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <!-- Ícone balão -->
                                            <iconPacks:PackIconMaterial Kind="MessageTextOutline"
                                                                             Width="22" Height="22"
                                                                             Foreground="White"/>
                                            <!-- Badge de notificação -->
                                            <Border Background="#1D4ED8"
                                                        CornerRadius="9"
                                                        MinWidth="18" Height="18"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,-6,-6,0"
                                                        Padding="3,0"
                                                        Visibility="{Binding ChatViewModel.TemMensagensNaoLidas, Converter={StaticResource BoolVis}}">
                                                <TextBlock Text="{Binding ChatViewModel.TotalNaoLidas, Converter={StaticResource BadgeConv}}"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Status do usuário logado -->
                    <TextBlock x:Name="TxtNomeUsuario"
                                   Foreground="#BFDBFE"
                                   FontSize="14"
                                   Margin="20,14,20,8">
                            <Ellipse Width="7" Height="7" Fill="#10B981"
                                     Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#10B981" Opacity="0.6"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Online" Foreground="#10B981" FontSize="13"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                            <Run Text="{Binding NomeUsuario, Mode=OneWay}"/>
                        </TextBlock>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard"
                            Style="{StaticResource NavBtnAtivo}"
                            Command="{Binding NavegarDashboardCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para o Dashboard" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnResiduos"
                            Style="{StaticResource NavBtn}"
                            Command="{Binding NavegarResiduosCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Cadastrar Resíduos" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePlusOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Cadastrar Resíduos" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEstoqueReverso"
                            Style="{StaticResource NavBtn}"
                            Command="{Binding NavegarEstoqueCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Estoque Reverso" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Warehouse" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Estoque Reverso" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnMapa"
                            Style="{StaticResource NavBtn}"
                            Command="{Binding NavegarMapaCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Mapa dos pontos de coleta" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapMarkerOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Mapa" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRelatorios"
                            Style="{StaticResource NavBtn}"
                            Command="{Binding NavegarRelatoriosCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de Relatórios" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Relatórios" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="8,0,8,12">
                    <Button x:Name="BtnConta"
                            Style="{StaticResource NavBtn}"
                            Command="{Binding NavegarContaCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para navegar para a tela de modificações da conta" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountCogOutline" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Minha Conta" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Border BorderThickness="0,1,0,0" BorderBrush="#1D4ED8" Margin="0,8,0,8"/>

                    <Button x:Name="BtnSair"
                            Style="{StaticResource NavBtnSair}"
                            Command="{Binding SairCommand}">
                        <Button.ToolTip>
                            <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                <TextBlock Text="Botão para sair da aplicação" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                            </ToolTip>
                        </Button.ToolTip>

                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Sair" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentView}"
                        Grid.Column="1"
                        Margin="20"/>
    </Grid>
</Window>