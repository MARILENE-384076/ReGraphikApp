<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    MinHeight="600"
    MinWidth="960"
    WindowStartupLocation="CenterScreen"
    Background="#F3F4F6"
    Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnAtivo" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#022654"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- [NOVO] Estilo exclusivo do botão Sair -->
        <Style x:Key="NavBtnSair" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="#87CEFA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#7F1D1D"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#093e75">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Row 0: logo + nome usuário -->
                    <RowDefinition Height="*"/>
                    <!-- Row 1: botões de navegação -->
                    <RowDefinition Height="Auto"/>
                    <!-- [NOVO] Row 2: botão Sair -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Foreground="White"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="20,24,20,20">
                    <TextBlock.Inlines>
                        <iconPacks:PackIconMaterial Kind="Recycle" Height="21" VerticalAlignment="Center" Width="26" />
                        <Run Text="ReGraphik"/>
                    </TextBlock.Inlines>
                </TextBlock>
                <TextBlock x:Name="TxtNomeUsuario"
                           Grid.Row="0"
                           Foreground="#BFDBFE"
                           FontSize="13"
                           Margin="20,70,20,20"
                           Text="Usuário"/>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard"
                            Style="{StaticResource NavBtnAtivo}"
                            Click="Dashboard_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnResiduos"
                            Style="{StaticResource NavBtn}"
                            Click="Residuos_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FilePlusOutline" Width="20" Height="20"  Margin="0,0,8,0"/>
                            <TextBlock Text="Cadastrar Resíduos" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnEstoqueReverso"
                            Style="{StaticResource NavBtn}"
                            Click="EstoqueReverso_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Warehouse" Width="20" Height="20"   Margin="0,0,8,0"/>
                            <TextBlock Text="Estoque Reverso" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnMapa"
                            Style="{StaticResource NavBtn}"
                            Click="Mapa_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MapMarkerOutline" Width="20" Height="20"  Margin="0,0,8,0"/>
                            <TextBlock Text="Mapa" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnRelatorios"
                            Style="{StaticResource NavBtn}"
                            Click="Relatorios_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="20" Height="20"  Margin="0,0,8,0"/>
                            <TextBlock Text="Relatórios" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- [NOVO] Botão Sair fixado no rodapé da barra lateral -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#1D4ED8" Margin="8,0,8,12">
                    <Button x:Name="BtnSair"
                            Style="{StaticResource NavBtnSair}"
                            Margin="0,8,0,0"
                            Click="Sair_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Width="20" Height="20" Margin="0,0,8,0"/>
                            <TextBlock Text="Sair" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame"
               Grid.Column="1"
               Margin="20"
               NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>