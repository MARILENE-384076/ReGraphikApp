<Window
    x:Class="ReGraphik.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ReGraphik"
    Height="720"
    Width="1200"
    WindowStartupLocation="CenterScreen"
    Background="#F3F4F6">

    <Grid>

        <!-- COLUNAS -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Background="#2563EB">

            <StackPanel>

                <!-- LOGO -->
                <TextBlock
                    Text="ReGraphik"
                    Foreground="White"
                    FontSize="28"
                    FontWeight="Bold"
                    Margin="20"/>

                <!-- BOTÕES -->
                <Button
                    Content="Dashboard"
                    Height="45"
                    Margin="10,5"
                    Background="#3B82F6"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Dashboard_Click"/>

                <Button
                    Content="Cadastrar Resíduos"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Residuos_Click"/>

                <Button
                    Content="Pontos de Coleta"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Pontos_Click"/>

                <Button
                    Content="Mapa"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Mapa_Click"/>

                <Button
                    Content="Relatórios"
                    Height="45"
                    Margin="10,5"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="16"
                    Click="Relatorios_Click"/>

            </StackPanel>

        </Border>

        <!-- CONTEÚDO -->
        <Grid Grid.Column="1"
              Margin="20">

            <!-- DASHBOARD -->
            <Grid x:Name="DashboardGrid">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Dashboard"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <!-- RESÍDUOS -->
            <Grid
                x:Name="ResiduosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Cadastrar Resíduos"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <!-- PONTOS -->
            <Grid
                x:Name="PontosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Pontos de Coleta"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <!-- MAPA -->
            <Grid
                x:Name="MapaGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Mapa"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

            <!-- RELATÓRIOS -->
            <Grid
                x:Name="RelatoriosGrid"
                Visibility="Collapsed">

                <Border
                    Background="White"
                    CornerRadius="12">

                    <TextBlock
                        Text="Relatórios"
                        FontSize="32"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>