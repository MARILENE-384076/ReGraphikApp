<Page x:Class="ReGraphik.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"  
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#F3F4F6" Title="Dashboard">

    <Page.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputControlStyle" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="12"
                    Padding="20,14" 
                    Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="Blue" 
                                CornerRadius="50" 
                                Width="50" 
                                Height="50">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                            </Border.Effect>
                        </Border>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B"/>

                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" 
                       Text="Dashboard" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#1E293B" 
                       Margin="0,10,0,557"/>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        Margin="0,0,0,20" 
                        Height="488">
                <Border Background="White" 
                        CornerRadius="12"
                        Padding="20,14" 
                        Margin="0,0,10,400"
                        Height="80" 
                        Width="231">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B"
                                       TextAlignment="Center"/>

                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" 
                        CornerRadius="12"
                        Padding="20,14" 
                        Margin="0,0,10,400"
                        Height="80" 
                        Width="231">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B" 
                                       TextAlignment="Center"/>    

                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0" 
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" 
                        CornerRadius="12"
                        Padding="20,14" 
                        Margin="0,0,10,400"
                        Height="80" 
                        Width="231">    
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B"
                                       TextAlignment="Center"/>

                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White" 
                        CornerRadius="12"
                        Padding="20,14" 
                        Margin="0,0,0,400"
                        Height="80" 
                        Width="229">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B"
                                       TextAlignment="Center"/>

                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</Page>