<Page x:Class="ReGraphik.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d"  
      d:DesignHeight="700" d:DesignWidth="950"
      Background="#F3F4F6" Title="Dashboard">

    <Page.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputControlStyle" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="12"
                    Padding="20,14" 
                    Margin="0,0,0,24">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#0d2a56" 
                                CornerRadius="25" 
                                Width="50" 
                                Height="50">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                            </Border.Effect>
                        </Border>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock x:Name= "TxtNomeUsuario"
                                       Text="Usuário" 
                                       FontSize="20"
                                       FontWeight="Bold" 
                                       Foreground="#1E293B"/>
                            <TextBlock Text="Administrador"
                                       FontSize="12" 
                                       Foreground="#64748B" 
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" 
                       Text="Dashboard" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#1E293B" 
                       Margin="0,0,0,16"/>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        Margin="0,0,0,24">

                <Border Background="#0d2a56" CornerRadius="12" Padding="20" Margin="0,0,16,0" Height="100" Width="210">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ResiduosDb}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Left"/>
                        <TextBlock Text="Resíduos Cadastrados" FontSize="15" Foreground="White" Margin="0,4,0,0" TextAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Background="#1649a2" CornerRadius="12" Padding="20" Margin="0,0,16,0" Height="100" Width="210">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Reaproveitar}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Left"/>
                        <TextBlock Text="Reaproveitados" FontSize="15" Foreground="White" Margin="0,4,0,0" TextAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Background="#3274ba" CornerRadius="12" Padding="20" Margin="0,0,16,0" Height="100" Width="210">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Estoque}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Left"/>
                        <TextBlock Text="Em Estoque" FontSize="15" Foreground="White" Margin="0,4,0,0" TextAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Background="#2f80ec" CornerRadius="12" Padding="20" Margin="0,0,0,0" Height="100" Width="210">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Total}" FontSize="18" FontWeight="Bold" Foreground="White" TextAlignment="Left"/>
                        <TextBlock Text="Total Econômico" FontSize="15" Foreground="White" Margin="0,4,0,0" TextAlignment="Left"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal"
                        Margin="0,0,0,24">

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,20,0" Height="280" Width="436">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Residuos Reaproveitados" FontSize="16" FontWeight="Bold" Foreground="#1E293B" TextAlignment="Left" Margin="0,0,0,12"/>

                        <lvc:PieChart Grid.Row="1" Series="{Binding GraficoStatus}" LegendLocation="Bottom" Hoverable="True" DataTooltip="{x:Null}"/>
                    </Grid>
                </Border>

                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,0" Height="280" Width="436">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Tipo de Resíduos" FontSize="16" FontWeight="Bold" Foreground="#1E293B" TextAlignment="Left" Margin="0,0,0,12"/>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding GraficoTipos}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding LabelsTipos}">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" IsEnabled="False" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Kg" LabelFormatter="{Binding FormatterTipos}" />
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="4" 
                    Background="White" 
                    CornerRadius="12" 
                    Padding="16" 
                    Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="#000"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Últimos Resíduos Cadastrados" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#1E293B" 
                               Margin="0,0,0,12" 
                               TextAlignment="Left"/>

                    <Button Content="Verificar" Width="140" Height="36" Background="#3274ba" BorderThickness="0" 
                            Foreground="White" FontWeight="Medium" HorizontalAlignment="Right">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <DataGrid x:Name="DgEstoque" 
                              Grid.Row="1"
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              Background="Transparent" 
                              BorderThickness="0" 
                              GridLinesVisibility="Horizontal" 
                              HorizontalGridLinesBrush="#F1F5F9"
                              RowHeight="48" 
                              IsReadOnly="True" 
                              HeadersVisibility="Column">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#1E40AF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="12,0,0,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Material" Binding="{Binding TipoResiduo}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Origem" Binding="{Binding Origem}" Width="1.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Quantidade (kg)" Binding="{Binding Quantidade}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#1E293B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Data" Binding="{Binding DataCadastro, StringFormat=\{0:dd/MM/yyyy\}}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#FEF08A" CornerRadius="10" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="#854D0E" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>