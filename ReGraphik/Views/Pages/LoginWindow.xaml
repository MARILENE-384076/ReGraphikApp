<Window x:Class="ReGraphik.Views.Pages.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReGraphik.ViewModels"
        Title="ReGraphik - Acesso"
        Height="680" Width="900"
        MinHeight="680" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <vm:LoginViewModel x:Key="LoginVM"/>
        <vm:CadastroViewModel x:Key="CadastroVM"/>

        <!-- Estilo dos TextBox -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Estilo dos PasswordBox -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Estilo dos Labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Estilo botão primário -->
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#093e75"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1649a2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Tab -->
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#093e75"/>
                                <Setter Property="Foreground" Value="#093e75"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#093e75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel esquerdo azul -->
        <Border Grid.Column="0" Background="#093e75">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                    <!-- Logo -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="♻️" FontSize="42" VerticalAlignment="Center"/>
                        <TextBlock Text="ReGraphik"
                                   FontSize="36"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Divisor -->
                    <Border Height="1" Background="#1649a2" Margin="0,0,0,24" Width="260"/>

                    <!-- Subtítulo -->
                    <TextBlock Text="Gestão inteligente de"
                               FontSize="16"
                               Foreground="#BFDBFE"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="resíduos industriais"
                               FontSize="16"
                               Foreground="#BFDBFE"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,32"/>

                    <!-- Ícones de destaque -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1649a2" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Dashboard em tempo real"
                                       Foreground="#BFDBFE"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#1649a2" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                <TextBlock Text="🗺️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Mapa de pontos de coleta"
                                       Foreground="#BFDBFE"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Background="#1649a2" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                <TextBlock Text="♻️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Controle de estoque reverso"
                                       Foreground="#BFDBFE"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Rodapé -->
                <TextBlock Grid.Row="2"
                           Text="© 2025 ReGraphik"
                           Foreground="#3274ba"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,20"/>
            </Grid>
        </Border>

        <!-- Painel direito claro -->
        <Border Grid.Column="1" Background="#F3F4F6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1"
                        Background="White"
                        CornerRadius="16"
                        Margin="40,0"
                        Padding="36,28">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="16" Opacity="0.08" Color="#000"/>
                    </Border.Effect>

                    <TabControl Background="Transparent" BorderThickness="0">

                        <!-- ABA LOGIN -->
                        <TabItem Header="Fazer Login" Style="{StaticResource TabStyle}">
                            <StackPanel DataContext="{StaticResource LoginVM}" Margin="0,24,0,0">

                                <TextBlock Text="Bem-vindo de volta!"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#1E293B"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Entre com suas credenciais para continuar."
                                           FontSize="13"
                                           Foreground="#64748B"
                                           Margin="0,0,0,24"/>

                                <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,16"/>

                                <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Senha, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputStyle}"
                                         Margin="0,0,0,28"/>

                                <Button Content="ENTRAR"
                                        Command="{Binding EntrarCommand}"
                                        Style="{StaticResource BtnPrimario}"/>
                            </StackPanel>
                        </TabItem>

                        <!-- ABA CADASTRO -->
                        <TabItem Header="Criar Nova Conta" Style="{StaticResource TabStyle}">
                            <StackPanel DataContext="{StaticResource CadastroVM}" Margin="0,24,0,0">

                                    <TextBlock Text="Crie sua conta"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#1E293B"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Preencha os dados abaixo para se cadastrar."
                                               FontSize="13"
                                               Foreground="#64748B"
                                               Margin="0,0,0,24"/>

                                    <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Senha, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             Margin="0,0,0,24"/>

                                    <Button Content="CADASTRAR"
                                            Command="{Binding CadastrarCommand}"
                                            Style="{StaticResource BtnPrimario}"/>
                                </StackPanel>
                        </TabItem>

                    </TabControl>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
