<Window x:Class="ReGraphik.Views.Pages.LoginWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReGraphik.ViewModels" 
        Title="ReGraphik - Acesso" Height="500" Width="400"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <vm:LoginViewModel x:Key="LoginVM" />
        <vm:CadastroViewModel x:Key="CadastroVM" />
    </Window.Resources>

    <Grid Background="#F3F4F6">
        <TabControl Margin="10">
            
            <TabItem Header="Fazer Login">
                <StackPanel DataContext="{StaticResource LoginVM}" Margin="20" VerticalAlignment="Center">
                    
                    <TextBlock Text="Seu Login:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,15"/>

                    <TextBlock Text="Sua Senha:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Senha, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,25"/>

                    <Button Content="ENTRAR" Command="{Binding EntrarCommand}" Padding="8" Background="#4CAF50" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Criar Nova Conta">
                <StackPanel DataContext="{StaticResource CadastroVM}" Margin="20" VerticalAlignment="Center">
                    
                    <TextBlock Text="Nome Completo:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="CPF:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="E-mail:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Crie um Login:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Text="Crie uma Senha:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Senha, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,20"/>

                    <Button Content="CADASTRAR" Command="{Binding CadastrarCommand}" Padding="8" Background="#2196F3" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
