<Window x:Class="ReGraphik.Views.Pages.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ReGraphik.ViewModels" xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        Title="ReGraphik - Acesso"
        Height="680" Width="900"
        MinHeight="680" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>


        <!-- Estilo dos TextBox -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Estilo dos PasswordBox -->
        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Estilo dos Labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Estilo botão primário -->
        <Style x:Key="BtnPrimario" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="#1649a2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1649a2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Tab -->
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#093e75"/>
                                <Setter Property="Foreground" Value="#093e75"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#093e75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#E2E8F0">

        <!-- Borda do container principal -->
        <Border Margin="40,30,40,30" CornerRadius="16" Background="White" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.15" Color="#000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- Aba de informações -->
                <Border Grid.Column="0" Background="#1649a2"
                        BorderBrush="#2563eb" 
                        BorderThickness="1,1,0,1" 
                        CornerRadius="16,0,0,16">
                    <Grid Margin="36,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Topo / Logo -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock Text="♻️" FontSize="36" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="ReGraphik" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- Conteúdo Central -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Gestão inteligente de resíduos industriais" FontSize="15" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,32"/>

                            <StackPanel HorizontalAlignment="Left" Margin="20,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#3274ba" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                        <iconPacks:PackIconMaterial Kind="ViewDashboardVariant" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Dashboard em tempo real" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Background="#3274ba" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                        <iconPacks:PackIconMaterial Kind="MapMarkerOutline" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Mapa de pontos de coleta" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#3274ba" CornerRadius="6" Width="32" Height="32" Margin="0,0,12,0">
                                        <iconPacks:PackIconMaterial Kind="Warehouse" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Controle de estoque reverso" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Footer -->
                        <TextBlock Grid.Row="2" Text="© 2026 ReGraphik" Foreground="#bae6fd" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    </Grid>
                </Border>

                <!-- Aba de formulários -->
                <Border Grid.Column="1" 
                        Background="White" 
                        BorderBrush="#CBD5E1" 
                        BorderThickness="1,1,1,1" 
                        CornerRadius="0,16,16,0" 
                        Padding="50,40">
                    <Grid>
                        <TabControl Background="Transparent" BorderThickness="0">

                            <!-- ABA LOGIN -->
                            <TabItem Header="Fazer Login" Style="{StaticResource TabStyle}">
                                <StackPanel Margin="0,32,0,0">
                                    <TextBlock Text="Bem-vindo de volta!" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                    <TextBlock Text="Entre com suas credenciais para continuar." FontSize="13" Foreground="#64748B" Margin="0,0,0,32"/>

                                    <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                                    <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                    <PasswordBox x:Name="TxtSenhaLogin" Style="{StaticResource PasswordStyle}" Margin="0,0,0,36"/>

                                    <Button Content="ENTRAR" Command="{Binding EntrarCommand}" CommandParameter="{Binding ElementName=TxtSenhaLogin}" Style="{StaticResource BtnPrimario}"/>
                                </StackPanel>
                            </TabItem>

                            <!-- ABA CADASTRO -->
                            <TabItem Header="Criar Nova Conta" Style="{StaticResource TabStyle}">

                                <TabItem.DataContext>
                                    <vm:CadastroViewModel />
                                </TabItem.DataContext>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                    <StackPanel Margin="0,20,10,0">
                                        <TextBlock Text="Crie sua conta" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                        <TextBlock Text="Preencha os dados abaixo para se cadastrar." FontSize="13" Foreground="#64748B" Margin="0,0,0,24"/>

                                        <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                                        <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                                        <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                                        <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                                        <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                        <PasswordBox x:Name="TxtSenhaCadastro" Style="{StaticResource PasswordStyle}" Margin="0,0,0,28"/>

                                        <Button Content="CADASTRAR" 
                                                Command="{Binding CadastrarCommand}" 
                                                CommandParameter="{Binding ElementName=TxtSenhaCadastro}" 
                                                Style="{StaticResource BtnPrimario}" 
                                                Margin="0,0,0,10"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
