<Window x:Class="ReGraphik.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views"
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        mc:Ignorable="d"
        Title="ReGraphik - Acesso" Height="680" Width="900"
        MinHeight="680" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#E2E8F0">
        <Border Margin="40,30,40,30" CornerRadius="16" Background="White" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.15" Color="#000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        BorderBrush="#1649a2" 
                        BorderThickness="1" 
                        CornerRadius="16,0,0,16"
                        ClipToBounds="True">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3274ba" Offset="0.0"/>
                            <GradientStop Color="#1649a2" Offset="0.5"/>
                            <GradientStop Color="#1E40AF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Canvas IsItemsHost="False">
                            <Ellipse Width="320" Height="320" 
                                     Stroke="White" StrokeThickness="32" 
                                     Opacity="0.08" 
                                     Canvas.Top="-80" Canvas.Right="-100"/>

                            <Ellipse Width="240" Height="240" 
                                     Stroke="White" StrokeThickness="24" 
                                     Opacity="0.05" 
                                     Canvas.Top="120" Canvas.Left="-120"/>

                            <Border Width="300" Height="300" 
                                    CornerRadius="150" 
                                    Opacity="0.12" 
                                    Canvas.Bottom="-100" Canvas.Left="-80">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                        </Canvas>

                        <Grid Margin="48,40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0,0,12,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Recycle" Height="21" VerticalAlignment="Center" Width="26" Foreground="White"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="REGRAPHIK" FontSize="16" FontWeight="Black" Foreground="White" Margin="0,0,0,-4"/>
                                    <TextBlock Text="WEB" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="400">
                                <TextBlock Text="Olá,&#x0a;seja bem-vindo!" 
                                           FontSize="46" 
                                           FontWeight="Bold" 
                                           Foreground="White" 
                                           TextAlignment="Left" 
                                           TextWrapping="Wrap"
                                           LineHeight="52"
                                           Margin="0,0,0,24"/>

                                <TextBlock Text="Gestão inteligente de resíduos industriais e eficiência ecológica para o seu negócio." 
                                           FontSize="15" 
                                           FontWeight="Normal" 
                                           Foreground="White" 
                                           Opacity="0.8"
                                           TextAlignment="Left" 
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" 
                                       Text="© 2026 ReGraphik" 
                                       Foreground="White" 
                                       Opacity="0.5"
                                       FontSize="11" 
                                       FontWeight="Medium"
                                       HorizontalAlignment="Left"/>
                        </Grid>
                        <Grid Visibility="{Binding DataContext.ExibirAlertaToken, ElementName=CadastroTab, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                            <Border Background="#40000000" CornerRadius="16,0,0,16"/>

                            <Border Background="White" 
                                    CornerRadius="12" 
                                    Width="320" 
                                    Height="190"
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.2"/>
                                </Border.Effect>

                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                                        <iconPacks:PackIconMaterial Kind="Key" Foreground="#1649a2" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Token de Cadastro Gerado" FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <TextBlock Text="Copie o token abaixo para validar o cadastro:" FontSize="12" Foreground="#64748B" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding DataContext.TokenGeradoAlerta, ElementName=CadastroTab}" 
                                                 IsReadOnly="True" 
                                                 FontSize="18" 
                                                 FontWeight="Bold" 
                                                 Foreground="#1649a2" 
                                                 Background="#F1F5F9" 
                                                 BorderThickness="0" 
                                                 Padding="8,6" 
                                                 TextAlignment="Center"/>
                                    </StackPanel>

                                    <Button Content="FECHAR AVISO" 
                                            Grid.Row="2" 
                                            Command="{Binding DataContext.FecharAlertaTokenCommand, ElementName=CadastroTab}" 
                                            Style="{StaticResource BtnPrimario}" 
                                            Height="32" 
                                            FontSize="11"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                
                <Border Grid.Column="1" 
                        Background="White" 
                        BorderBrush="#CBD5E1" 
                        BorderThickness="1" 
                        CornerRadius="0,16,16,0" 
                        Padding="50,40">
                    <Grid>
                        <TabControl Background="Transparent" BorderThickness="0">

                            <TabItem Header="Fazer Login" Style="{StaticResource TabStyle}">
                                <Grid Margin="32,16,32,0">
                                    <StackPanel Margin="0,10,0,10" HorizontalAlignment="Stretch">
                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="Faça Login" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                            <TextBlock Text="Entre com suas credenciais para continuar." FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>

                                        <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                        <Grid x:Name="GridCamposSenha" Margin="0,0,0,4">
                                            <PasswordBox x:Name="TxtSenhaLogin" Style="{StaticResource PasswordStyle}" Padding="10,0,35,0"/>
                                            <TextBox x:Name="TxtSenhaVisivelLogin" Style="{StaticResource InputStyle}" Padding="10,0,35,0" Visibility="Collapsed"/>
                                            <Button x:Name="BtnRevelarSenha" 
                                                    Command="{Binding RevelarSenhaCommand}" 
                                                    CommandParameter="{Binding ElementName=GridCamposSenha}"
                                                    HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                <iconPacks:PackIconMaterial x:Name="IconeOlho" Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <TextBlock Text="{Binding MensagemErroGeral}" Foreground="DarkRed" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                        <Button Content="ENTRAR" IsDefault="True" Command="{Binding EntrarCommand}" CommandParameter="{Binding ElementName=TxtSenhaLogin}" Style="{StaticResource BtnPrimario}" HorizontalAlignment="Stretch">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                                    <TextBlock Text="Botão para logar no sistema" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                                                </ToolTip>
                                            </Button.ToolTip>
                                        </Button>

                                        <Button x:Name="BtnEsqueciSenha" Content="Esqueci minha Senha" Background="Transparent" BorderThickness="0" Foreground="#0284C7" FontSize="12" FontWeight="SemiBold" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,7,0,0" Command="{Binding EsqueciSenhaCommand}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem x:Name="CadastroTab" Header="Criar Nova Conta" Style="{StaticResource TabStyle}">
                                <Grid Margin="32,16,32,0">

                                    <ScrollViewer x:Name="PainelFormularioCadastro"  
                      VerticalScrollBarVisibility="Auto"  
                      HorizontalScrollBarVisibility="Disabled">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.FormularioEnviado, ElementName=CadastroTab}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>

                                        <StackPanel HorizontalAlignment="Stretch" Margin="0,10,15,10">
                                            <StackPanel Margin="0,0,0,24">
                                                <TextBlock Text="Crie sua conta" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                <TextBlock Text="Preencha os dados abaixo para iniciar seu cadastro no ReGraphik." FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaNome}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaCpf}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaEmail}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                            <Grid x:Name="GridCamposSenhaCadastro" MinHeight="35" Margin="0,0,0,4" VerticalAlignment="Center">
                                                <PasswordBox x:Name="TxtSenhaCadastro" Style="{StaticResource PasswordStyle}" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Padding="10,0,40,0" Margin="0"/>
                                                <TextBox x:Name="TxtSenhaVisivelCadastro" Style="{StaticResource InputStyle}" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Padding="10,0,40,0" Visibility="Collapsed" Margin="0"/>
                                                <Button x:Name="BtnRevelarSenhaCadastro" Command="{Binding RevelarSenhaCadastroCommand}" CommandParameter="{Binding ElementName=GridCamposSenhaCadastro}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                    <iconPacks:PackIconMaterial x:Name="IconeOlho1" Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,20" Foreground="DarkRed"/>

                                            <TextBlock Text="{Binding MensagemErroGeral}" Foreground="DarkRed" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                            <Button Content="CADASTRAR" 
                                                    IsDefault="True" 
                                                    Command="{Binding CadastrarCommand}" 
                                                    CommandParameter="{Binding ElementName=GridCamposSenhaCadastro}" 
                                                    HorizontalAlignment="Stretch">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Content" Value="PROCESSANDO..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Button.ToolTip>
                                                    <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                                        <TextBlock Text="Botão para cadastrar no sistema" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                                                    </ToolTip>
                                                </Button.ToolTip>
                                            </Button>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.FormularioEnviado, ElementName=CadastroTab}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsTokenValido, ElementName=CadastroTab}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="Validação de Segurança" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                                        <TextBlock Text="Um código foi enviado para seu e-mail. Digite-o abaixo para ativar sua conta." TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,20"/>
                                        <TextBlock Text="Token" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding TokenDigitado, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding MensagemErroToken}" Foreground="DarkRed" Margin="0,0,0,15"/>
                                        <Button Content="VALIDAR TOKEN" Command="{Binding ValidarTokenCommand}" Style="{StaticResource BtnPrimario}"/>
                                    </StackPanel>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTokenValido, ElementName=CadastroTab}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="✓" FontSize="70" Foreground="Green" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Cadastro concluído!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
                                        <TextBlock Text="Sua conta foi ativada com sucesso." Foreground="#64748B" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>
                        
                    </Grid>
                    
                </Border>
                
            </Grid>
        </Border>
        
    </Grid>
</Window>