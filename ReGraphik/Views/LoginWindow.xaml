<Window x:Class="ReGraphik.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views" 
        xmlns:vm="clr-namespace:ReGraphik.ViewModels" 
        xmlns:iconPacks="clr-namespace:MahApps.Metro.IconPacks;assembly=MahApps.Metro.IconPacks.Material"
        mc:Ignorable="d"
        Title="ReGraphik - Acesso" Height="680" Width="900"
        MinHeight="680" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#E2E8F0">
        <Border Margin="40,30,40,30" CornerRadius="16" Background="White" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.15" Color="#000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1649a2"
                        BorderBrush="#2563eb" 
                        BorderThickness="1,1,0,1" 
                        CornerRadius="16,0,0,16">
                    <Grid Margin="36,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,120,100">
                            <TextBlock Text="♻️" FontSize="36" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="ReGraphik" FontSize="32" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <TextBlock Text="Bem-vindo de volta!" FontSize="50" FontWeight="Bold" Foreground="White" 
                                       HorizontalAlignment="Center" TextAlignment="Left" Margin="20" TextWrapping="Wrap" Width="288"/>
                            <TextBlock Text="Gestão inteligente de resíduos industriais" FontSize="18" FontWeight="Medium" Foreground="White" 
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,32" TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Text="© 2026 ReGraphik" Foreground="#bae6fd" FontSize="11" HorizontalAlignment="Center" Margin="30"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        BorderBrush="#CBD5E1" 
                        BorderThickness="1,1,1,1" 
                        CornerRadius="0,16,16,0" 
                        Padding="50,40">
                    <Grid>
                        <TabControl Background="Transparent" BorderThickness="0">

                            <TabItem Header="Fazer Login" Style="{StaticResource TabStyle}">
                                <Grid Margin="32,16,32,0">
                                    <StackPanel Margin="0,10,0,10" HorizontalAlignment="Stretch">

                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="Faça Login" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                            <TextBlock Text="Entre com suas credenciais para continuar." FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>

                                        <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                        <Grid x:Name="GridCamposSenha" Margin="0,0,0,4">
                                            <PasswordBox x:Name="TxtSenhaLogin" Style="{StaticResource PasswordStyle}" Padding="10,0,35,0"/>
                                            <TextBox x:Name="TxtSenhaVisivelLogin" Style="{StaticResource InputStyle}" Padding="10,0,35,0" Visibility="Collapsed"/>

                                            <Button x:Name="BtnRevelarSenha" 
                                                    Command="{Binding RevelarSenhaCommand}" 
                                                    CommandParameter="{Binding ElementName=GridCamposSenha}"
                                                    HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                <iconPacks:PackIconMaterial x:Name="IconeOlho" Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <TextBlock Text="{Binding MensagemErroGeral}" 
                                                   Foreground="DarkRed" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,16"/>

                                        <Button Content="ENTRAR" 
                                                IsDefault="True"
                                                Command="{Binding EntrarCommand}" 
                                                CommandParameter="{Binding ElementName=TxtSenhaLogin}" 
                                                Style="{StaticResource BtnPrimario}"
                                                HorizontalAlignment="Stretch">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                                    <TextBlock Text="Botão para logar no sistema" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                                                </ToolTip>
                                            </Button.ToolTip>
                                        </Button>

                                        <Button x:Name="BtnEsqueciSenha"
                                                Content="Esquece minha Senha"
                                                Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="#0284C7"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Cursor="Hand"
                                                VerticalAlignment="Bottom"
                                                Margin="0,7,0,0"
                                                Command="{Binding EsqueciSenhaCommand}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Criar Nova Conta" Style="{StaticResource TabStyle}">
                                <TabItem.DataContext>
                                    <vm:CadastroViewModel/>
                                </TabItem.DataContext>

                                <Grid Margin="32,16,32,0">

                                    <StackPanel x:Name="PainelValidacaoToken" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="Chave de Acesso Necessária" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <TextBlock Text="Para criar uma conta no ReGraphik, insira o token de autorização fornecido pelo seu administrador." FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <TextBlock Text="Token de Autorização" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding TokenDigitado, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,12" HorizontalAlignment="Stretch"/>

                                        <TextBlock Text="{Binding MensagemErroToken}" Foreground="DarkRed" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                        <Button Content="VERIFICAR TOKEN" 
                                                Command="{Binding ValidarTokenCommand}"
                                                Style="{StaticResource BtnPrimario}"
                                                HorizontalAlignment="Stretch"/>

                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTokenValido}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                    </StackPanel>

                                    <ScrollViewer x:Name="PainelFormularioCadastro" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel HorizontalAlignment="Stretch" Margin="0,10,0,10">

                                            <StackPanel Margin="0,0,0,24">
                                                <TextBlock Text="Crie sua conta" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4" TextWrapping="Wrap"/>
                                                <TextBlock Text="Preencha os dados abaixo para se cadastrar." FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaNome}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaCpf}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaEmail}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,0,0,12" Foreground="DarkRed"/>

                                            <TextBlock Text="Senha" Style="{StaticResource LabelStyle}"/>
                                            <Grid x:Name="GridCamposSenhaCadastro" Margin="0,0,0,4">
                                                <PasswordBox x:Name="TxtSenhaCadastro" Style="{StaticResource PasswordStyle}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                                <TextBox x:Name="TxtSenhaVisivelCadastro" Style="{StaticResource InputStyle}" Padding="10,0,35,0" Visibility="Collapsed"/>

                                                <Button x:Name="BtnRevelarSenhaCadastro" 
                                                        Command="{Binding RevelarSenhaCadastroCommand}" 
                                                        CommandParameter="{Binding ElementName=GridCamposSenhaCadastro}"
                                                        HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                    <iconPacks:PackIconMaterial x:Name="IconeOlho1" Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,20" Foreground="DarkRed"/>

                                            <TextBlock Text="{Binding MensagemErroGeral}" 
                                                       Foreground="DarkRed" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,16"/>

                                            <Button Content="CADASTRAR" 
                                                    IsDefault="True"
                                                    Command="{Binding CadastrarCommand}" 
                                                    CommandParameter="{Binding ElementName=TxtSenhaCadastro}" 
                                                    Style="{StaticResource BtnPrimario}"
                                                    HorizontalAlignment="Stretch">
                                                <Button.ToolTip>
                                                    <ToolTip Style="{Binding BtnToolTip}"  BorderThickness="0" HasDropShadow="True">
                                                        <TextBlock Text="Botão para cadastrar uma nova conta" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                                                    </ToolTip>
                                                </Button.ToolTip>
                                            </Button>
                                        </StackPanel>

                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTokenValido}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                    </ScrollViewer>

                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>