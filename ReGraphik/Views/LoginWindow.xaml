<Window x:Class="ReGraphik.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="ReGraphik - Acesso" 
        Height="680" 
        Width="900"
        MinHeight="680" 
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Icon="/Imgs/logoRegraphik.png">

    <Window.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#E2E8F0">
        <Border Margin="40,30,40,30" CornerRadius="16" Background="White" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.15" Color="#000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        BorderBrush="#1649a2" 
                        BorderThickness="1,1,0,1" 
                        CornerRadius="16,0,0,16"
                        ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3274ba" Offset="0.0"/>
                            <GradientStop Color="#1649a2" Offset="0.5"/>
                            <GradientStop Color="#1E40AF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <Canvas IsItemsHost="False">
                            <Ellipse Width="320" Height="320" 
                                     Stroke="White" StrokeThickness="32" 
                                     Opacity="0.08" 
                                     Canvas.Top="-80" Canvas.Right="-100"/>

                            <Ellipse Width="240" Height="240" 
                                     Stroke="White" StrokeThickness="24" 
                                     Opacity="0.05" 
                                     Canvas.Top="120" Canvas.Left="-120"/>

                            <Border Width="300" Height="300" 
                                    CornerRadius="150" 
                                    Opacity="0.12" 
                                    Canvas.Bottom="-100" Canvas.Left="-80">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="White" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                        </Canvas>

                        <Grid Margin="48,40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <Grid Margin="0,0,12,0" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Recycle" Height="21" VerticalAlignment="Center" Width="26" Foreground="White"/>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="REGRAPHIK" FontSize="16" FontWeight="Black" Foreground="White" Margin="0,0,0,-4"/>
                                    <TextBlock Text="WEB" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="400">
                                <TextBlock Text="Olá,&#x0a;seja bem-vindo!" 
                                           FontSize="46" 
                                           FontWeight="Bold" 
                                           Foreground="White" 
                                           TextAlignment="Left" 
                                           TextWrapping="Wrap"
                                           LineHeight="52"
                                           Margin="0,0,0,24"/>

                                <TextBlock Text="Gestão inteligente de resíduos industriais e eficiência ecológica para o seu negócio." 
                                           FontSize="15" 
                                           FontWeight="Normal" 
                                           Foreground="White" 
                                           Opacity="0.8"
                                           TextAlignment="Left" 
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2" 
                                       Text="© 2026 ReGraphik" 
                                       Foreground="White" 
                                       Opacity="0.5"
                                       FontSize="11" 
                                       FontWeight="Medium"
                                       HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Visibility="{Binding DataContext.ExibirAlertaToken, ElementName=CadastroTab, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                            <Border Background="#40000000" CornerRadius="16,0,0,16"/>

                            <Border Background="White" 
                                    CornerRadius="12" 
                                    Width="320" 
                                    MinHeight="190"
                                    Height="Auto"
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="3" Opacity="0.2"/>
                                </Border.Effect>

                                <Grid Margin="20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                                        <iconPacks:PackIconMaterial Kind="Key" Foreground="#1649a2" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Token de Cadastro Gerado" FontSize="15" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="Copie o token abaixo para validar o cadastro:" FontSize="12" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBox Text="{Binding DataContext.TokenGeradoAlerta, ElementName=CadastroTab}" 
                                                 IsReadOnly="True" 
                                                 FontSize="18" 
                                                 FontWeight="Bold" 
                                                 Foreground="#1649a2" 
                                                 Background="#F1F5F9" 
                                                 BorderThickness="0" 
                                                 Padding="8,6" 
                                                 TextAlignment="Center"/>
                                    </StackPanel>

                                    <Button Content="FECHAR AVISO" 
                                            Grid.Row="2" 
                                            Command="{Binding DataContext.FecharAlertaTokenCommand, ElementName=CadastroTab}" 
                                            Style="{StaticResource BtnPrimario}" 
                                            Height="36" 
                                            FontSize="11"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        BorderBrush="#CBD5E1" 
                        BorderThickness="0,1,1,1" 
                        CornerRadius="0,16,16,0" 
                        Padding="50,40">
                    <Grid>
                        <TabControl Background="Transparent" BorderThickness="0">

                            <!-- Tela de Login -->
                            <TabItem Header="Fazer Login" Style="{StaticResource TabStyle}">
                                <Grid Margin="32,16,32,0">
                                    <StackPanel Margin="0,10,0,10" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="Faça Login" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                            <TextBlock Text="Entre com suas credenciais para continuar." FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <TextBlock Style="{StaticResource LabelStyle}">
                                            <Run Text="Login"/>
                                            <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                                        </TextBlock>
                                        <Grid Margin="0,0,0,4">
                                            <TextBox x:Name="TxtLogin" 
                                                 Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                                                 Style="{StaticResource InputStyle}" 
                                                 Padding="35,0,10,0" 
                                                 VerticalContentAlignment="Center"
                                                 HorizontalAlignment="Stretch"/>

                                            <iconPacks:PackIconMaterial Kind="Account" 
                                                                    Width="17" 
                                                                    Height="17" 
                                                                    Margin="10,0,0,0" 
                                                                    Foreground="#94A3B8" 
                                                                    HorizontalAlignment="Left" 
                                                                    VerticalAlignment="Center"
                                                                    IsHitTestVisible="False"/>

                                        </Grid>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,5,0,16" Foreground="DarkRed"/>

                                        <TextBlock Style="{StaticResource LabelStyle}">
                                            <Run Text="Senha"/>
                                            <Run Text="*" Foreground="Red" FontWeight="Bold"/>
                                        </TextBlock>
                                        <Grid x:Name="GridCamposSenha" Margin="0,0,0,4">
                                            <Grid Margin="0,0,0,4">
                                                <PasswordBox x:Name="TxtSenhaLogin" 
                                                             Style="{StaticResource PasswordStyle}" 
                                                             Padding="35,0,10,0" 
                                                             Height="40" 
                                                             VerticalContentAlignment="Center"/>

                                                <iconPacks:PackIconMaterial Kind="Lock" 
                                                                        Width="17" 
                                                                        Height="17" 
                                                                        Margin="10,0,0,0" 
                                                                        Foreground="#94A3B8" 
                                                                        HorizontalAlignment="Left" 
                                                                        VerticalAlignment="Center"
                                                                        IsHitTestVisible="False"/>
                                            </Grid>
                                            <TextBox x:Name="TxtSenhaVisivelLogin" Style="{StaticResource InputStyle}" Padding="10,0,35,0" Visibility="Collapsed" Height="40" VerticalContentAlignment="Center"/>
                                            <Button x:Name="BtnRevelarSenha" 
                                                    Command="{Binding RevelarSenhaCommand}" 
                                                    CommandParameter="{Binding ElementName=GridCamposSenha}"
                                                    HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                <iconPacks:PackIconMaterial x:Name="IconeOlho" Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <TextBlock Text="{Binding MensagemErroGeral}" Foreground="DarkRed" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                        <Button Content="ENTRAR" IsDefault="True" Command="{Binding EntrarCommand}" CommandParameter="{Binding ElementName=TxtSenhaLogin}" Style="{StaticResource BtnPrimario}" HorizontalAlignment="Stretch" Height="40">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource BtnTooltip}" BorderThickness="0" HasDropShadow="True">
                                                    <TextBlock Text="Botão para logar no sistema" FontWeight="SemiBold" FontSize="12" Margin="4,2"/>
                                                </ToolTip>
                                            </Button.ToolTip>
                                        </Button>

                                        <Button x:Name="BtnEsqueciSenha" Content="Esqueci minha Senha" Background="Transparent" BorderThickness="0" Foreground="#0284C7" FontSize="12" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Left" Margin="0,12,0,0" Command="{Binding EsqueciSenhaCommand}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <!-- Tela de cadastro -->
                            <TabItem x:Name="CadastroTab" Header="Criar Nova Conta" Style="{StaticResource TabStyle}">
                                <Grid Margin="32,16,32,0">

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExibirSolicitacaoAcesso}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <StackPanel Margin="0,0,0,24">
                                            <TextBlock Text="Validação de Acesso" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                            <TextBlock Text="Insira seu e-mail corporativo para iniciar o processo de cadastro." FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>

                                        <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4"/>
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaEmail}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                        <Button Content="SOLICITAR ACESSO" 
                    Command="{Binding SolicitarAcessoCommand}" 
                    Height="40">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Ocupado}" Value="True">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Content" Value="PROCESSANDO POST NA API..."/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>


                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SolicitacaoEnviada}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <StackPanel x:Name="PainelValidacaoToken">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsTokenValido}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <TextBlock Text="Validação de Segurança" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                                            <TextBlock Text="Um token de ativação foi gerado. Insira o código abaixo para prosseguir." TextWrapping="Wrap" Foreground="#64748B" Margin="0,0,0,12"/>

                                            <TextBlock Text="{Binding MensagemErroGeral}" Foreground="#16A34A" FontSize="13" FontWeight="Medium" TextWrapping="Wrap" Margin="0,0,0,16" HorizontalAlignment="Left"/>

                                            <TextBlock Text="Chave interceptada (Debug API):" Style="{StaticResource LabelStyle}" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding MensagemErroToken, Mode=OneWay}" 
                         Style="{StaticResource InputStyle}" 
                         IsReadOnly="True" 
                         Background="#EFF6FF" 
                         Foreground="#1E40AF" 
                         FontWeight="Bold" 
                         Focusable="False" 
                         Margin="0,0,0,16"/>

                                            <TextBlock Text="Digite o Token de Ativação" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding TokenDigitado, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,20" Height="40"/>

                                            <Button Content="VALIDAR TOKEN" 
                        Command="{Binding ValidarTokenCommand}" 
                        Height="40">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OcupadoToken}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Content" Value="VALIDANDO..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <StackPanel x:Name="PainelFormularioFinal">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ExibirFormularioCompleto}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <StackPanel Margin="0,0,0,16">
                                                <TextBlock Text="Complete seu Cadastro" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,4"/>
                                                <TextBlock Text="Token validado com sucesso! Defina seus dados finais de acesso." FontSize="13" Foreground="#64748B"/>
                                            </StackPanel>

                                            <TextBlock Text="E-mail Autorizado" Style="{StaticResource LabelStyle}" Foreground="#64748B"/>
                                            <TextBox Text="{Binding Email, Mode=OneWay}" Style="{StaticResource InputStyle}" IsReadOnly="True" Background="#F1F5F9" Foreground="#64748B" Opacity="0.7" Focusable="False" Margin="0,0,0,10"/>

                                            <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                                            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,4"/>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaNome}" Margin="0,0,0,10" Foreground="DarkRed"/>

                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding CPF, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                                    <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaCpf}" Margin="0,4,0,0" Foreground="DarkRed"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                                                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                                    <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaLogin}" Margin="0,4,0,0" Foreground="DarkRed"/>
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Text="Senha" Style="{StaticResource LabelStyle}" Margin="0,6,0,0"/>
                                            <Grid x:Name="GridCamposSenhaCadastro" MinHeight="35" Margin="0,0,0,4">
                                                <PasswordBox x:Name="TxtSenhaCadastro" Style="{StaticResource PasswordStyle}" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Padding="10,0,40,0" Height="40"/>
                                                <TextBox x:Name="TxtSenhaVisivelCadastro" Style="{StaticResource InputStyle}" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Padding="10,0,40,0" Visibility="Collapsed" Height="40"/>
                                                <Button x:Name="BtnRevelarSenhaCadastro" Command="{Binding RevelarSenhaCadastroCommand}" CommandParameter="{Binding ElementName=GridCamposSenhaCadastro}" HorizontalAlignment="Right" Width="30" Height="30" Margin="0,0,6,0" Background="Transparent" BorderThickness="0">
                                                    <iconPacks:PackIconMaterial Kind="Eye" Foreground="#64748B" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                            <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding MensaSenha}" Margin="0,0,0,16" Foreground="DarkRed"/>

                                            <Button Content="FINALIZAR CADASTRO" IsDefault="True" Command="{Binding FinalizarCadastroCommand}" CommandParameter="{Binding ElementName=GridCamposSenhaCadastro}" Style="{StaticResource BtnPrimario}" Height="40"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CadastroFinalizadoComSucesso}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="✓" FontSize="70" Foreground="Green" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Cadastro concluído!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
                                    </StackPanel>

                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>