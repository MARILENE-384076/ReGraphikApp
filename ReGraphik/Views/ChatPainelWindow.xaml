<Window x:Class="ReGraphik.Views.ChatPainelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views"
        xmlns:converters="clr-namespace:ReGraphik.Converters"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        MinWidth="300"
        MinHeight="400"
        Width="380"
        Height="560">

    <Window.Resources>
        <converters:MensagemAlinhamentoConverter x:Key="AlinhamentoConv"/>
        <converters:MensagemCorFundoConverter    x:Key="CorFundoConv"/>
        <converters:MensagemCorTextoConverter    x:Key="CorTextoConv"/>
        <converters:NaoLidasVisibilidadeConverter x:Key="NaoLidasVisConv"/>
        <converters:DataHoraMensagemConverter    x:Key="DataHoraConv"/>
        <converters:BadgeNotificacaoConverter    x:Key="BadgeConv"/>
        <BooleanToVisibilityConverter            x:Key="BoolVis"/>
    </Window.Resources>


    <Grid>

        <ResizeGrip Style="{StaticResource GripStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Panel.ZIndex="10"
                    Margin="0,0,2,2"/>

        <Border Background="White"
                CornerRadius="12"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="Black" Opacity="0.12"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>


                <Border Grid.Row="0"
                        Background="#093e75"
                        CornerRadius="12,12,0,0"
                        Padding="14,12"
                        MouseLeftButtonDown="Cabecalho_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource BtnIconeStyle}"
                                Command="{Binding VoltarListaCommand}"
                                Visibility="{Binding TemConversaSelecionada, Converter={StaticResource BoolVis}}"
                                Margin="0,0,6,0">
                            <iconPacks:PackIconMaterial Kind="ArrowLeft" Width="16" Height="16" Foreground="White"/>
                        </Button>


                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="15">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Mensagens"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemConversaSelecionada}" Value="True">
                                                <Setter Property="Text" Value="{Binding NomeConversaAtual}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Online"
                                       Foreground="#10B981"
                                       FontSize="11"
                                       Visibility="{Binding TemConversaSelecionada, Converter={StaticResource BoolVis}}"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource BtnIconeStyle}"
                                Command="{Binding AbrirNovaConversaCommand}"
                                ToolTip="Nova conversa"
                                Margin="0,0,4,0">
                            <iconPacks:PackIconMaterial Kind="PencilPlusOutline" Width="16" Height="16" Foreground="White"/>
                        </Button>


                        <Button Grid.Column="3"
                                Style="{StaticResource BtnIconeStyle}"
                                ToolTip="Fechar"
                                Click="BtnFechar_Click">
                            <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>


                <Grid Grid.Row="1">


                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TemConversaSelecionada}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,4">
                            <StackPanel>


                                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Carregando}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <iconPacks:PackIconMaterial Kind="MessageOutline"
                                                                Width="48" Height="48"
                                                                Foreground="{DynamicResource CinzaClaroColor}"
                                                                HorizontalAlignment="Center"/>
                                    <TextBlock Text="Nenhuma conversa ainda"
                                               Foreground="{DynamicResource TextoCinzaColor}" FontSize="13"
                                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                    <TextBlock Text="Clique no lápis para iniciar"
                                               Foreground="{DynamicResource CinzaClaroColor}" FontSize="12"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>


                                <TextBlock Text="Carregando..."
                                           Foreground="{DynamicResource TextoCinzaColor}" FontSize="13"
                                           HorizontalAlignment="Center" Margin="0,40,0,0"
                                           Visibility="{Binding Carregando, Converter={StaticResource BoolVis}}"/>


                                <ItemsControl ItemsSource="{Binding Conversas}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Button Style="{StaticResource ItemConversaStyle}"
                                                    Command="{Binding DataContext.SelecionarConversaCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="40" Height="40"
                                                            Background="{DynamicResource AzulMedioColor}" CornerRadius="20"
                                                            HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Iniciais}"
                                                                   Foreground="White" FontWeight="Bold"
                                                                   FontSize="14"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,4,0">
                                                        <TextBlock Text="{Binding UsuarioNome}"
                                                                   FontWeight="SemiBold" FontSize="14"
                                                                   Foreground="{DynamicResource TextoPadraoColor}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding UltimaMensagem}"
                                                                   FontSize="12" Foreground="{DynamicResource CinzaColor}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>


                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding HorarioFormatado}"
                                                                   FontSize="11" Foreground="{DynamicResource TextoCinzaColor}"
                                                                   HorizontalAlignment="Right"/>
                                                        <Border Background="#EF4444" CornerRadius="10"
                                                                Padding="5,1" MinWidth="20"
                                                                HorizontalAlignment="Right" Margin="0,4,0,0"
                                                                Visibility="{Binding MensagensNaoLidas, Converter={StaticResource NaoLidasVisConv}}">
                                                            <TextBlock Text="{Binding MensagensNaoLidas}"
                                                                       Foreground="White" FontSize="11"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>


                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TemConversaSelecionada}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>

                            <RowDefinition Height="Auto"/>

                        </Grid.RowDefinitions>


                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      x:Name="ScrollMensagens"
                                      Padding="12,8">
                            <ItemsControl ItemsSource="{Binding Mensagens}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <StackPanel HorizontalAlignment="{Binding EhMinhaMensagem, Converter={StaticResource AlinhamentoConv}}"
                                                    Margin="0,3"
                                                    MaxWidth="{Binding ActualWidth,
                                                               RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                               Converter={StaticResource AlinhamentoConv}}">

                                            <TextBlock Text="{Binding RemetenteNome}"
                                                       FontSize="11" Foreground="{DynamicResource CinzaColor}"
                                                       Margin="4,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EhMinhaMensagem}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>


                                            <Border Background="{Binding EhMinhaMensagem, Converter={StaticResource CorFundoConv}}"
                                                    CornerRadius="12" Padding="10,8">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="Black" Opacity="0.06"/>
                                                </Border.Effect>
                                                <TextBlock Text="{Binding Texto}"
                                                           Foreground="{Binding EhMinhaMensagem, Converter={StaticResource CorTextoConv}}"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"/>
                                            </Border>


                                            <TextBlock Text="{Binding DataHora, Converter={StaticResource DataHoraConv}}"
                                                       FontSize="10" Foreground="{DynamicResource TextoCinzaColor}"
                                                       HorizontalAlignment="{Binding EhMinhaMensagem, Converter={StaticResource AlinhamentoConv}}"
                                                       Margin="4,2,4,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>


                        <Border Grid.Row="1"
                                BorderBrush="#E2E8F0"
                                BorderThickness="0,1,0,0"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="14,8"
                                        Margin="0,0,8,0">
                                    <TextBox Text="{Binding TextoMensagem, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             FontSize="13"
                                             MaxHeight="80"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="False"
                                             VerticalAlignment="Center">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding EnviarMensagemCommand}"/>
                                        </TextBox.InputBindings>
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TextBox">
                                                            <Grid>
                                                                <TextBlock Text="Digite uma mensagem..."
                                                                           Foreground="{DynamicResource TextoCinzaColor}" FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           IsHitTestVisible="False">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding TextoMensagem}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <ScrollViewer x:Name="PART_ContentHost"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Border>

                                <Button Grid.Column="1"
                                        Style="{StaticResource BtnEnviarStyle}"
                                        Command="{Binding EnviarMensagemCommand}"
                                        ToolTip="Enviar mensagem (Enter)">
                                    <iconPacks:PackIconMaterial Kind="Send" Width="16" Height="16" Foreground="White"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>


                    <Border CornerRadius="0,0,12,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Background"  Value="#80000000"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MostrarNovaConversa}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Border Background="White" CornerRadius="8"
                                Margin="12" Padding="0,0,0,8"
                                VerticalAlignment="Top"
                                MaxHeight="{Binding ActualHeight,
                                            RelativeSource={RelativeSource AncestorType=Window},
                                            Converter={StaticResource AlinhamentoConv}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>


                                <Border Grid.Row="0"
                                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                        Padding="14,10">
                                    <Grid>
                                        <TextBlock Text="Nova Conversa"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource TextoPadraoColor}" VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right"
                                                Style="{StaticResource BtnIconeStyle}"
                                                Command="{Binding FecharNovaConversaCommand}">
                                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Foreground="{DynamicResource CinzaColor}"/>
                                        </Button>
                                    </Grid>
                                </Border>


                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="8,4">
                                    <ItemsControl ItemsSource="{Binding UsuariosDisponiveis}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- CORRIGIDO: AncestorType=Window (era UserControl) -->
                                                <Button Style="{StaticResource ItemConversaStyle}"
                                                        Command="{Binding DataContext.IniciarConversaCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="44"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Width="36" Height="36"
                                                                Background="{DynamicResource AzulMedioColor}" CornerRadius="18">
                                                            <TextBlock Text="{Binding Iniciais}"
                                                                       Foreground="White" FontWeight="Bold"
                                                                       FontSize="13"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Center"
                                                                    Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Nome}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{DynamicResource TextoPadraoColor}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Email}"
                                                                       FontSize="11" Foreground="{DynamicResource TextoCinzaColor}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Border>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>
