<UserControl x:Class="ReGraphik.Views.UserControls.ContaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReGraphik.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#F3F4F6">


    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="4" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="#000"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

                <Grid Margin="24,24,24,16" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,39,0">
                        <TextBlock Text="Meu Perfil" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Gerencie os dados da sua conta." FontSize="14" Foreground="#64748B" Margin="0,5,0,20"/>

                        <TextBlock Text="Nome Completo" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtNome" Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="CPF" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtCpf" Text="{Binding Cpf}" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="E-mail" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtEmail" Text="{Binding Email}" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Login" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TxtLogin" Text="{Binding Login}" Style="{StaticResource InputStyle}" Margin="0,0,0,12"/>

                        <TextBlock Text="Nova Senha" Style="{StaticResource LabelStyle}"/>
                        <PasswordBox x:Name="TxtSenha" Style="{StaticResource PasswordStyle}" Margin="0,0,0,24"/>

                        <Button x:Name="BtnSalvar" Content="Salvar Alterações" Height="45" HorizontalAlignment="Stretch"
                                Style="{StaticResource BtnPrimaryStyle}" FontSize="15" FontWeight="Bold" 
                                Cursor="Hand" BorderThickness="0">
                        </Button>
                    </StackPanel>


                    <Grid Grid.Column="2" VerticalAlignment="Stretch" Margin="10,80,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Viewbox Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" MaxWidth="350" MaxHeight="350" Margin="0,0,0,16">
                            <Border x:Name="FotoContainer" Width="200" Height="200" CornerRadius="100" BorderThickness="1" BorderBrush="#E2E8F0">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ImgFoto, TargetNullValue={x:Null}, FallbackValue={x:Null}}" 
                                    Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                        </Viewbox>

                        <Button x:Name="BtnMudarFoto" Grid.Row="1" Command="{Binding SelecionarFotoCommand}" Content="Mudar Foto"
                                Height="35" Width="130" HorizontalAlignment="Center" Margin="0,10,0,0"
                                FontSize="13" FontWeight="Bold" 
                                Cursor="Hand" BorderThickness="0" Style="{StaticResource BtnFoto}">
                        </Button>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>