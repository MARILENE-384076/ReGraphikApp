<Window x:Class="ReGraphik.Views.TokenEmailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Width="500"
        SizeToContent="Height" 
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="#F8FAFC" CornerRadius="16" Padding="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="18" Opacity="0.15" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Aba de Email -->
                <Border Grid.Row="0" Background="#F1F5F9" CornerRadius="16,16,0,0" Padding="20,14" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="De:" FontWeight="SemiBold" Foreground="#64748B" Width="50" FontSize="12"/>
                                <TextBlock Text="AppReGraphik &lt;reghaphiktcc@gmail.com&gt;" Foreground="#334155" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="Para:" FontWeight="SemiBold" Foreground="#64748B" Width="50" FontSize="12"/>
                                <TextBlock x:Name="TxtDestinatarioSimulado" Text="usuario@email.com" Foreground="#334155" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                <TextBlock Text="Assunto:" FontWeight="SemiBold" Foreground="#64748B" Width="55" FontSize="12"/>
                                <TextBlock Text="🔑 Seu Código de Verificação ReGraphik" Foreground="#1E293B" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Content="✕" 
                                Width="24" Height="24" 
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-4,-4,0"
                                Foreground="#94A3B8" Background="Transparent" BorderThickness="0"
                                FontSize="12" Cursor="Hand" Click="BtnFechar_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" Margin="20,16,20,16" Padding="24" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Olá!" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextoPadraoColor}" Margin="0,0,0,8"/>

                        <TextBlock Text="Você solicitou um acesso ou recebeu um convite para o sistema ReGraphik. Use o token em destaque abaixo para concluir a validação da sua conta:"
                                   FontSize="13" Foreground="#475569" TextWrapping="Wrap" LineHeight="18" LineStackingStrategy="BlockLineHeight"/>

                        <!-- Tela de Token -->
                        <Border Background="#F0FFF4" CornerRadius="10" Padding="16,14" BorderBrush="#86EFAC" BorderThickness="1" Margin="0,20,0,20">
                            <StackPanel>
                                <TextBlock Text="CÓDIGO DE VERIFICAÇÃO" FontSize="10" FontWeight="Bold" Foreground="#15803D" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border Background="White" CornerRadius="8" Padding="20,10" BorderBrush="#86EFAC" BorderThickness="1" MinWidth="160">
                                        <TextBlock x:Name="TxtTokenExibido" 
                                                   Text="XYZ-123" 
                                                   FontFamily="Courier New" FontSize="24" FontWeight="Bold"
                                                   Foreground="{DynamicResource AzulMedioColor}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Button Width="40" Height="46" Margin="6,0,0,0"
                                            Background="White" BorderBrush="#86EFAC" BorderThickness="1"
                                            Cursor="Hand" ToolTip="Copiar Código" Click="BtnCopiar_Click">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                        <iconPacks:PackIconMaterial Kind="ContentCopy" Width="14" Height="14" Foreground="#15803D"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="Válido por 48 horas · Uso único" FontSize="11" Foreground="{DynamicResource CinzaColor}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Se você não solicitou este código, ignore este e-mail por segurança." FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="20,4,20,0">
                    <TextBlock Text="ℹ️ Copie o código e clique ao lado para prosseguir." 
                               VerticalAlignment="Center" Foreground="#64748B" FontSize="12" HorizontalAlignment="Left"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>