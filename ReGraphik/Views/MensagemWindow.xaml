<Window x:Class="ReGraphik.Views.MensagemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Width="460"
        SizeToContent="Height" 
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#1A000000" Margin="10">
        <Border Background="#FFFFFF" 
            CornerRadius="36" 
            MaxWidth="440" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Padding="32,24,32,32"
            BorderBrush="#E5E7EB"
            BorderThickness="1">
            <Border.Effect>
                <!-- Sombra suave e moderna de alta dispersão -->
                <DropShadowEffect BlurRadius="30" Opacity="0.08" ShadowDepth="4" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Botão de Fechar -->
                <Button Grid.Row="0" Grid.Column="1" 
                    Content="✕" 
                    Width="24" 
                    Height="24" 
                    Margin="0,-8,-8,0"
                    HorizontalAlignment="Right" 
                    Style="{StaticResource ModernCloseButton}"
                    Click="BtnFechar_Click"/>

                <!-- Caixa do Ícone -->
                <Border Grid.Row="1" Grid.Column="0" 
                    Background="#EAFDF5" 
                    BorderBrush="#A7F3D0"
                    BorderThickness="1.5"
                    Width="76" 
                    Height="76" 
                    CornerRadius="22" 
                    VerticalAlignment="Top" 
                    Margin="0,8,20,24">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.15" ShadowDepth="1" Color="#10B981"/>
                    </Border.Effect>
                    <!-- Ícone de folha -->
                    <TextBlock x:Name="TxtIcone" 
                           Text="🍃"
                           FontSize="32" 
                           Foreground="#10B981" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="0,-2,0,0"/>
                </Border>

                <!-- Bloco de Textos -->
                <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="0,8,0,24">
                    <!-- Título -->
                    <TextBlock x:Name="TxtTitulo" 
                           Text="SUA SOLICITAÇÃO&#x0a;FOI ENVIADA" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#4A5568" 
                           TextWrapping="Wrap"
                           LineHeight="24"
                           LineStackingStrategy="BlockLineHeight"/>

                    <!-- Subtítulo -->
                    <TextBlock x:Name="TxtMensagem" 
                           Text="Entraremos em contato&#x0a;em breve."
                           FontSize="16" 
                           Foreground="#718096" 
                           TextWrapping="Wrap" 
                           Margin="0,10,0,0" 
                           LineHeight="20"
                           LineStackingStrategy="BlockLineHeight"/>
                </StackPanel>

                <!-- Botão -->
                <Button Grid.Row="2" Grid.Column="1" 
                    Content="Ok, entendi" 
                    Height="46" 
                    HorizontalAlignment="Left" 
                    Style="{StaticResource ModernRoundedButton}"
                    Click="BtnFechar_Click"/>
            </Grid>
        </Border>
    </Grid>

</Window>