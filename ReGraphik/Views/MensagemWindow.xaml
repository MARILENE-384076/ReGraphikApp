<Window x:Class="ReGraphik.Views.MensagemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Width="440"
        SizeToContent="Height" 
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="White" CornerRadius="16" Padding="24,20,24,24">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.12" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                        Content="✕" 
                        Width="28" 
                        Height="28" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,-8,-8,0"
                        Foreground="{DynamicResource TextoCinzaColor}"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        Cursor="Hand"
                        Click="BtnFechar_Click"/>

                <Grid Grid.Row="1" Margin="0,4,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBorder"
                            Grid.Column="0" 
                            Background="#F0FDF4" 
                            BorderBrush="#DCFCE7"
                            BorderThickness="1"
                            Width="56" 
                            Height="56" 
                            CornerRadius="28" 
                            VerticalAlignment="Top" 
                            HorizontalAlignment="Center"
                            Margin="0,0,16,0">

                        <iconPacks:PackIconMaterial x:Name="MessageIcon"
                                                    Kind="CheckCircleOutline"
                                                    Foreground="{DynamicResource VerdeColor}" 
                                                    Width="28" 
                                                    Height="28"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtTitulo" 
                                   Text="Sucesso!" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource TextoPadraoColor}" 
                                   TextWrapping="Wrap"/>

                        <TextBlock x:Name="TxtMensagem" 
                                   Text="O resíduo foi cadastrado com sucesso no sistema."
                                   FontSize="14" 
                                   Foreground="{DynamicResource CinzaColor}" 
                                   TextWrapping="Wrap" 
                                   Margin="0,6,0,0" 
                                   LineHeight="20"
                                   LineStackingStrategy="BlockLineHeight"/>
                    </StackPanel>
                </Grid>

                <Button Grid.Row="2" 
                        x:Name="BtnAcao"
                        Content="Entendi" 
                        Height="38" 
                        Width="110"
                        HorizontalAlignment="Right" 
                        Style="{StaticResource RoundedButtonStyle}"
                        Background="{DynamicResource AzulMedioColor}" 
                        Foreground="White" 
                        FontWeight="SemiBold" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="BtnFechar_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>