<Window x:Class="ReGraphik.Views.MensagemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Width="460"
        Height="280"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid Background="#33000000">

        <Border Background="#F9FBFB" 
                CornerRadius="24" 
                Width="420" 
                Height="240" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                Padding="24,16,24,20"
                BorderBrush="#D0D3D4"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.10" ShadowDepth="3" Color="#33000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="75"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Grid.Column="1" 
                        Content="✕" 
                        Width="32" 
                        Height="32" 
                        HorizontalAlignment="Right" 
                        Style="{StaticResource CloseXButtonStyle}"
                        Click="BtnFechar_Click"/>

                <Border Grid.Row="1" Grid.Column="0" 
                        Background="#EAFAF1" 
                        Height="73" 
                        CornerRadius="18" 
                        VerticalAlignment="Top" 
                        Margin="0,4,7,0">
                    <TextBlock x:Name="TxtIcone" FontSize="28" Foreground="#2ECC71" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="10,4,0,0">
                    <TextBlock x:Name="TxtTitulo" FontSize="22" FontWeight="Bold" Foreground="#1A1D20"/>
                    <TextBlock x:Name="TxtMensagem" 
                               FontSize="14" Foreground="#5A6578" TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="18"/>
                </StackPanel>

                <Button Grid.Row="2" Grid.Column="1" 
                        Content="Ok, entendi" 
                        Width="130" 
                        Height="38" 
                        HorizontalAlignment="Right" 
                        Style="{StaticResource BtnPrimario}"
                        Click="BtnFechar_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>