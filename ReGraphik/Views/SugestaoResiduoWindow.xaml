<Window x:Class="ReGraphik.Views.SugestaoResiduoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views"
        mc:Ignorable="d"
        Title="Sugestões de Reaproveitamento" 
        Height="550" Width="900"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None" 
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#F8FAFC" CornerRadius="16" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="💡 Diretório de Sugestões de Reaproveitamento"
                           FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Selecione o Resíduo Alvo:" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding ResiduosEstoque}" 
                              SelectedItem="{Binding ResiduoSelecionado}"
                              DisplayMemberPath="TipoResiduo" 
                              Height="38"
                              VerticalContentAlignment="Center"
                              Padding="10,0"/>

                    <TextBlock Margin="2,6,0,0" FontSize="12" Foreground="{DynamicResource CinzaColor}">
                        <Run Text="Especificação: "/>
                        <Run Text="{Binding ResiduoSelecionado.Especificacao, FallbackValue='Nenhum selecionado'}" FontWeight="Medium" Foreground="#334155"/>
                        <Run Text=" — Condição: "/>
                        <Run Text="{Binding ResiduoSelecionado.Condicao, FallbackValue='-'}" Foreground="#334155"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="2" Text="{Binding Mensagem}" FontSize="12" Foreground="#1E40AF" Margin="2,0,0,8" FontWeight="Medium"/>

            <Grid Grid.Row="3" Margin="0,4,0,16">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#EFF6FF" CornerRadius="6,6,0,0" Padding="12,10" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0">
                        <TextBlock Text="Ideias de Destinos Mapeadas no Sistema" FontWeight="Bold" Foreground="#1E40AF" FontSize="13"/>
                    </Border>

                    <ListBox ItemsSource="{Binding SugestoesFiltradasView}"
                             DisplayMemberPath="DescricaoSugestao"
                             Background="White"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             Padding="8"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="Margin" Value="0,3"/>
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="SnapsToDevicePixels" Value="True"/>

                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F1F5F9"/>
                                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EFF6FF"/>
                                        <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        <Setter Property="Foreground" Value="#1E40AF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Grid>

            <Grid Grid.Row="4" Margin="0,4,0,0">
                <Button Content="Voltar para o Estoque"
                        Style="{StaticResource BtnSecondaryStyle}"
                        Click="BtnFechar_Click"
                        Height="38" 
                        Width="200"
                        HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</Window>