<Window x:Class="ReGraphik.Views.DetalhesResiduoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReGraphik.Views"
        mc:Ignorable="d"
        Title="Informações Detalhadas do Resíduo" 
        Height="720" 
        Width="750" Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None" 
        ShowInTaskbar="False" 
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        UseLayoutRounding="True">


    <Border Background="#F8FAFC" CornerRadius="16" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15" Color="#0F172A"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="24,20,24,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#EFF6FF" 
                            CornerRadius="12" 
                            Width="44" 
                            Height="44" 
                            Margin="0,0,16,0"
                            VerticalAlignment="Center">

                        <Path Data="M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M12,17V12H17V14H14V17H12Z" 
                              Fill="#3B82F6" 
                              Width="22" 
                              Height="22" 
                              Stretch="Uniform"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Ficha Técnica do Resíduo" 
                                   FontFamily="Segoe UI, Arial"
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#0F172A"/>
                        <TextBlock Text="{Binding IdCard, StringFormat='Identificador único do lote: {0}'}" 
                                   FontFamily="Segoe UI, Arial"
                                   FontSize="13" 
                                   Foreground="#475569" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="✕" Width="32" Height="32" Click="BtnFechar_Click"
                        Background="Transparent" BorderThickness="0" Foreground="#64748B" FontWeight="Bold" FontSize="14" VerticalAlignment="Top">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E2E8F0"/>
                                    <Setter Property="Foreground" Value="#0F172A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="#F1F5F9" Margin="24,8,24,12" Height="150" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding Anexo, TargetNullValue='pack://application:,,,/Assets/placeholder.png', FallbackValue='pack://application:,,,/Assets/placeholder.png'}" 
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <Border Background="#CC1E293B" CornerRadius="6" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12">
                        <TextBlock Text="{Binding Status, TargetNullValue='Sem Status'}" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2" Margin="24,4,24,16" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Background="White" Padding="16" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="TIPO DE MATERIAL RESTRITO" FontSize="10" FontWeight="Bold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding TipoResiduo}" FontSize="20" FontWeight="Bold" Foreground="#0F172A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <DockPanel Margin="0,0,0,12">
                        <Border DockPanel.Dock="Top" Background="#F1F5F9" CornerRadius="10,10,0,0" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#3B82F6" Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"/>
                                <TextBlock Text="Informações de Rastreabilidade" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="0,0,10,10" Padding="8">
                            <StackPanel>
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,2">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➜" Foreground="#3B82F6" FontSize="12" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Origem / Setor Gerador:" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Origem}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,2">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➜" Foreground="#3B82F6" FontSize="12" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Projeto de Origem:" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Projeto, TargetNullValue='Não associado'}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,2">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➜" Foreground="#3B82F6" FontSize="12" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Quantidade Armazenada:" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Quantidade}" FontSize="13" FontWeight="Bold" Foreground="#2563EB"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding UnidadeMedida}" FontSize="13" FontWeight="Bold" Foreground="#2563EB"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,2">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➜" Foreground="#3B82F6" FontSize="12" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Condição Física / Estado:" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Condicao}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="4,2">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="➜" Foreground="#3B82F6" FontSize="12" Margin="4,0,12,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Data de Cadastro:" FontSize="13" Foreground="#64748B"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DataCadastro, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" FontSize="13" FontWeight="SemiBold" Foreground="#334155" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,12">
                        <Border DockPanel.Dock="Top" Background="#F1F5F9" CornerRadius="10,10,0,0" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#10B981" Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"/>
                                <TextBlock Text="Características Físicas e Dimensões" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="0,0,10,10" Padding="12">
                            <StackPanel>
                                <StackPanel Margin="4,0,4,12">
                                    <TextBlock Text="Especificação Técnica:" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Especificacao, TargetNullValue='Nenhuma especificação detalhada fornecida.'}" FontSize="13" Foreground="#334155" TextWrapping="Wrap"/>
                                </StackPanel>

                                <Separator Background="#E2E8F0" Margin="4,0,4,12"/>

                                <UniformGrid Columns="2" Margin="0,2">
                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Comprimento" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding DimensoesCm, TargetNullValue='0'}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                                <TextBlock Text=" " FontSize="11" Foreground="#64748B" VerticalAlignment="Bottom"/>
                                                <TextBlock Text="{Binding UnidadeDimensao}" FontSize="11" Foreground="#64748B" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4,0">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Largura" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding DimensoesLm, TargetNullValue='0'}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                                <TextBlock Text=" " FontSize="11" Foreground="#64748B" VerticalAlignment="Bottom"/>
                                                <TextBlock Text="{Binding UnidadeDimensao}" FontSize="11" Foreground="#64748B" VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </DockPanel>

                    <DockPanel Margin="0,0,0,4">
                        <Border DockPanel.Dock="Top" Background="#F1F5F9" CornerRadius="10,10,0,0" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#F59E0B" Width="4" Height="14" CornerRadius="2" Margin="0,0,8,0"/>
                                <TextBlock Text="Observações do Material" FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="0,0,10,10" Padding="16">
                            <TextBlock Text="{Binding Observacao, TargetNullValue='Nenhuma observação interna registrada.'}" 
                                       FontSize="13" 
                                       Foreground="#475569" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic"/>
                        </Border>
                    </DockPanel>

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="3" Margin="24,0,24,24">
                <Button Content="Fechar Visualização"
                        Style="{StaticResource BtnSecondaryStyle}"
                        Click="BtnFechar_Click"
                        Height="40" 
                        Width="220"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Grid>
    </Border>
</Window>