<UserControl x:Class="ReGraphik.Views.Controls.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:ReGraphik.Views.Controls"
             xmlns:converters="clr-namespace:ReGraphik.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024" Background="#F3F4F6">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:CaminhoParaImagemConverter x:Key="CaminhoParaImagemConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,24,24,16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,24">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Perfil do Usuário -->
                        <Grid Width="50" Height="50">
                            <Border CornerRadius="25" BorderBrush="#E2E8F0" BorderThickness="1" Background="{DynamicResource AzulEscuroColor}">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                                </Border.Effect>
                            </Border>

                            <!-- Inicias do nome -->
                            <TextBlock Text="{Binding Iniciais, FallbackValue='?'}" 
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"/>

                            <Border CornerRadius="25" ClipToBounds="True">
                                <Border.Background>
                                    <!-- O Converter assume toda a responsabilidade de criar a imagem ou retornar nulo sem estourar exceção -->
                                    <ImageBrush ImageSource="{Binding FotoPerfil}" 
                                                Stretch="UniformToFill"/>
                                </Border.Background>
                            </Border>

                            <Ellipse Width="12" Height="12" 
                                     Fill="{DynamicResource VerdeColor}"
                                     Stroke="{DynamicResource AzulEscuroColor}" 
                                     StrokeThickness="1.5"
                                     HorizontalAlignment="Right" 
                                     VerticalAlignment="Bottom"
                                     Margin="0,0,2,2"/>
                        </Grid>

                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock x:Name="TxtNomeUsuario"
                                       Text="{Binding NomeUsuario}"
                                       FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextoColor}"/>

                            <!-- Campos do Usuário -->
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding Perfil}" FontSize="12" Foreground="{DynamicResource CinzaColor}"/>
                                <TextBlock Text=" • " FontSize="12" Foreground="{DynamicResource TextoCinzaColor}" Margin="4,0"/>
                                <TextBlock Text="Online" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource VerdeColor}"/>
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AzulMedioColor}" Margin="0,0,0,16"/>

            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource AzulEscuroColor}" CornerRadius="12" Padding="20" Height="100" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ResiduosDb}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Total de itens registrados" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource AzulMedioColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Reaproveitar}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Materiais reaproveitados" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource AzulClaroColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Estoque}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Quantidade armazenada" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{DynamicResource AzulMuitoClaroColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Total}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Economia gerada" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20" Height="300" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Resíduos Reaproveitados" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextoColor}" Margin="0,0,0,12"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding GraficoPizzaModel}"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="20" Height="300" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Tipo de Resíduos" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextoColor}" Margin="0,0,0,12"/>
                        <oxy:PlotView Grid.Row="1" Model="{Binding GraficoBarrasModel}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,16" MinHeight="300">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Últimos Resíduos Cadastrados" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextoColor}" VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid x:Name="DgEstoque" Grid.Row="1"
                              ItemsSource="{Binding UltimosResiduos}"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="White"
                              RowHeight="48" IsReadOnly="True" HeadersVisibility="Column">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource AzulFundoColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AzulMedioColor}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CinzaColor}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Material" Binding="{Binding TipoResiduo}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextoColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Origem" Binding="{Binding Origem}" Width="1.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CinzaEscuroColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Quantidade (kg)" Binding="{Binding Quantidade}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextoPadraoColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Data" Binding="{Binding DataCadastro, StringFormat=\{0:dd/MM/yyyy\}}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CinzaColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                CornerRadius="12" Padding="10,4"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="#FFFFFF"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>