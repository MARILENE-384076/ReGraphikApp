<UserControl x:Class="ReGraphik.Views.Controls.MapaControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReGraphik.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#F8FAFC">
    
    <!-- Recursos da página -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho com título e busca -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="20,14" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Mapa de Pontos de Coleta" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextoPadraoColor}"/>
                    <TextBlock Text="Visualize os pontos de coleta de resíduos no mapa" FontSize="12" Foreground="{DynamicResource CinzaColor}" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Área de busca -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Buscar cidade:" FontSize="13" Foreground="{DynamicResource CinzaColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Border Background="#F8FAFC" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                        <TextBox x:Name="TxtCidade" Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}" Width="160" Height="36"
                             Background="Transparent" BorderThickness="0" Padding="10,0" FontSize="13" VerticalContentAlignment="Center"/>
                    </Border>
                    <Button Content="Buscar" Command="{Binding BuscarCommand}"
                        Height="36" Width="80" Margin="8,0,0,0" Background="{DynamicResource AzulMedioColor}" Foreground="White"
                        BorderThickness="0" Cursor="Hand" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Área do mapa e lista de pontos -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="16,12" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📍" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Pontos encontrados" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextoPadraoColor}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PontosAtuais.Count, FallbackValue=0}" FontSize="11" FontWeight="Bold" Foreground="#2563EB"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">

                        <ListView x:Name="ListaPontos" ItemsSource="{Binding PontosAtuais}" BorderThickness="0" Padding="0" 
                      ScrollViewer.VerticalScrollBarVisibility="Auto" Background="Transparent"
                      SelectionChanged="ListaPontos_SelectionChanged">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,12" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Background="Transparent" Cursor="Hand">
                                        <Grid HorizontalAlignment="Stretch" Width="240">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" Background="#DBEAFE" CornerRadius="8" VerticalAlignment="Top">
                                                <TextBlock Text="📍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Stretch">

                                                <TextBlock Text="{Binding NomePonto}" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="{DynamicResource TextoPadraoColor}" 
                                                       TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Cidade}" 
                                                       FontSize="11" 
                                                       Foreground="{DynamicResource CinzaColor}" 
                                                       Margin="0,3,0,0" 
                                                       TextWrapping="Wrap"/>

                                                <Border Background="#D1FAE5" CornerRadius="4" Padding="6,2" Margin="0,4,0,0" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding ResiduosAceitos}" 
                                                           FontSize="10" 
                                                           Foreground="#065F46" 
                                                           FontWeight="SemiBold" 
                                                           TextWrapping="Wrap"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Background="White" Visibility="{Binding MostrarEstadoVazio, Converter={StaticResource BoolToVis}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center"/>
                                <TextBlock Text="Busque uma cidade" FontSize="13" Foreground="{DynamicResource TextoCinzaColor}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <TextBlock Text="para ver os pontos" FontSize="13" Foreground="{DynamicResource TextoCinzaColor}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Background="White" Visibility="{Binding IsCarregando, Converter={StaticResource BoolToVis}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="⏳" FontSize="36" HorizontalAlignment="Center"/>
                                <TextBlock Text="Buscando pontos..." FontSize="13" Foreground="{DynamicResource TextoCinzaColor}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <WebBrowser x:Name="MapaBrowser" Navigated="MapaBrowser_Navigated"/>

                    <Border x:Name="MapaPlaceholder" Background="White" CornerRadius="12" Visibility="{Binding MostrarEstadoVazio, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🗺" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="Mapa de Coleta" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextoPadraoColor}" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            <TextBlock Text="Digite uma cidade e clique em Buscar" FontSize="13" Foreground="{DynamicResource TextoCinzaColor}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
