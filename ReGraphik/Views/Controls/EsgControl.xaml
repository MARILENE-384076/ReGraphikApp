<UserControl x:Class="ReGraphik.Views.Controls.EsgControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Card Interativo Estilo Web Premium -->
            <Style x:Key="CardInteractiveStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Padding" Value="24"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="16" Opacity="0.03" Color="#0F172A"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="24" Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.08" Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)" To="8" Duration="0:0:0.25"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="16" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.03" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)" To="4" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Botão Moderno com Glow Hidratado -->
            <Style x:Key="ModernButtonStyle" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)" To="0.96" Duration="0:0:0.05"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)" To="0.96" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(Button.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="LinkButtonStyle" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#2563EB"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                                    <Setter TargetName="txt" Property="Foreground" Value="#1D4ED8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Fundo em Gradiente Sutil (Padrão Web SaaS) -->
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F1F5F9" Offset="0.0"/>
            <GradientStop Color="#F8FAFC" Offset="0.3"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <!-- Transição de Entrada Fluida -->
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                    <DoubleAnimation Storyboard.TargetName="MainTransform" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid x:Name="MainGrid" Margin="36,28,36,28">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="MainTransform" Y="0"/>
        </Grid.RenderTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Refinado -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <StackPanel>
                <TextBlock Text="Painel de Impacto e Diretrizes ESG" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                <TextBlock Text="Monitore indicadores, gerencie a conformidade corporativa e acelere sua certificação ambiental." FontSize="13" Foreground="{DynamicResource CinzaColor}" Margin="0,6,0,0"/>
            </StackPanel>

            <Button Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Right" Command="{Binding ExportarPdfCommand}" Height="42" Padding="20,0" Background="#1E40AF" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#1E40AF"/>
                </Button.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📥 " VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14"/>
                    <TextBlock Text="Exportar Diretrizes (PDF)" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Conteúdo Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,12,0">

                <!-- Grid de Cards ESG com Linhas de Destaque -->
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card E (Ambiental) -->
                    <Grid Grid.Column="0">
                        <Border Style="{StaticResource CardInteractiveStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Border Background="#E6F4EA" CornerRadius="8" Width="38" Height="38" Margin="0,0,12,0">
                                            <TextBlock Text="E" FontSize="18" FontWeight="Bold" Foreground="#137333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Ambiental" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock Text="Impacto e Circularidade" FontSize="12" Foreground="{DynamicResource CinzaColor}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Background="#E6F4EA" CornerRadius="10" Padding="8,2" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <TextBlock Text="• Ativo" FontSize="10" FontWeight="SemiBold" Foreground="#137333"/>
                                    </Border>
                                </Grid>

                                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22" Margin="0,0,0,16"
                                           Text="O ReGraphik transforma resíduos gráficos — papel, cartão e vinil — em matéria-prima circular. Reduz emissões de CO₂ e custos de descarte logístico evitando aterros comuns."/>

                                <Border Grid.Row="2" Background="#F0FDF4" CornerRadius="8" Padding="14,10">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#166534" FontWeight="Medium" LineHeight="16"
                                               Text="📊 Indicadores: kg cadastrados · pontos homologados · estimativa de CO₂ evitado."/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Glow Line Superior -->
                        <Border Height="4" Background="#34A853" VerticalAlignment="Top" CornerRadius="16,16,0,0"/>
                    </Grid>

                    <!-- Card S (Social) -->
                    <Grid Grid.Column="2">
                        <Border Style="{StaticResource CardInteractiveStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Border Background="#E8F0FE" CornerRadius="8" Width="38" Height="38" Margin="0,0,12,0">
                                            <TextBlock Text="S" FontSize="18" FontWeight="Bold" Foreground="#1A73E8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Social" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock Text="Cadeia Produtiva" FontSize="12" Foreground="{DynamicResource CinzaColor}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Background="#E8F0FE" CornerRadius="10" Padding="8,2" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <TextBlock Text="• Ativo" FontSize="10" FontWeight="SemiBold" Foreground="#1A73E8"/>
                                    </Border>
                                </Grid>

                                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22" Margin="0,0,0,16"
                                           Text="Conecta empresas a cooperativas e catadores, fomentando renda estável. O ecossistema transforma sobras em novos subprodutos comerciais locais."/>

                                <Border Grid.Row="2" Background="#EFF6FF" CornerRadius="8" Padding="14,10">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#1D4ED8" FontWeight="Medium" LineHeight="16"
                                               Text="🤝 Benefícios: inclusão de catadores · economia circular ativa · engajamento local."/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Glow Line Superior -->
                        <Border Height="4" Background="#4285F4" VerticalAlignment="Top" CornerRadius="16,16,0,0"/>
                    </Grid>

                    <!-- Card G (Governança) -->
                    <Grid Grid.Column="4">
                        <Border Style="{StaticResource CardInteractiveStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Border Background="#F3E8FF" CornerRadius="8" Width="38" Height="38" Margin="0,0,12,0">
                                            <TextBlock Text="G" FontSize="18" FontWeight="Bold" Foreground="#6B21A8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Governança" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock Text="Rastreabilidade" FontSize="12" Foreground="{DynamicResource CinzaColor}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Background="#F3E8FF" CornerRadius="10" Padding="8,2" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <TextBlock Text="• Seguro" FontSize="10" FontWeight="SemiBold" Foreground="#6B21A8"/>
                                    </Border>
                                </Grid>

                                <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22" Margin="0,0,0,16"
                                           Text="Histórico auditável contendo origem, volume e destino final. Garante conformidade total com a PNRS (Lei 12.305/10), facilitando laudos e auditorias."/>

                                <Border Grid.Row="2" Background="#FAF5FF" CornerRadius="8" Padding="14,10">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#6B21A8" FontWeight="Medium" LineHeight="16"
                                               Text="📋 Diferenciais: dados para laudos · histórico protegido · relatórios GRI/CDP."/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- Glow Line Superior -->
                        <Border Height="4" Background="#A855F7" VerticalAlignment="Top" CornerRadius="16,16,0,0"/>
                    </Grid>
                </Grid>

                <!-- Seção Inferior: ISO 14001 Premium Card -->
                <Border Background="White" CornerRadius="16" Padding="28" BorderThickness="1,1,1,1" BorderBrush="#E2E8F0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.02" Color="#0F172A"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Conteúdo Esquerdo da ISO -->
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="#FEF3C7" CornerRadius="10" Width="42" Height="42">
                                    <TextBlock Text="🏅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <TextBlock Text="Certificação Ambiental ISO 14001 via INMETRO" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Caminho prático para homologação de sustentabilidade da sua empresa" FontSize="12" Foreground="{DynamicResource CinzaColor}"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock TextWrapping="Wrap" Foreground="#475569" FontSize="13" LineHeight="22" Margin="0,0,0,24"
                                       Text="O ReGraphik automatiza sua base documental. Os relatórios gerados servem como evidência de auditoria para acelerar o processo junto aos órgãos certificadores."/>

                            <!-- Timeline Interna Estilo Web -->
                            <StackPanel>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="18" Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="1" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" Text="Gere o Relatório Comprobatório"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource CinzaColor}" FontSize="12" Text="Exporte o PDF consolidado de movimentações na aba de Relatórios."/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="18" Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="2" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" Text="Acesse o Portal do INMETRO"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource CinzaColor}" FontSize="12" Text="Identifique um Organismo de Certificação Ambiental (OCA) credenciado."/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="18" Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="3" FontWeight="Bold" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13" Text="Auditoria Documental"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource CinzaColor}" FontSize="12" Text="Apresente os dados do sistema ReGraphik como prova de destino correto."/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#FEF3C7" CornerRadius="18" Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                                        <TextBlock Text="✨" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock FontWeight="SemiBold" Foreground="#D97706" FontSize="13" Text="Homologação e Certificado"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource CinzaColor}" FontSize="12" Text="Sua empresa inserida formalmente no sistema nacional Certifiq."/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <!-- Ações Laterais Dinâmicas -->
                        <Grid Grid.Column="2" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Ações Disponíveis" FontWeight="Bold" Foreground="#0F172A" FontSize="13" Margin="0,0,0,14"/>

                                <Button Style="{StaticResource ModernButtonStyle}" Command="{Binding IrParaRelatoriosCommand}" Height="42" Background="#D97706" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,24">
                                    <Button.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15" Color="#D97706"/>
                                    </Button.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊 " VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Text="Gerar Relatório" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Border Background="#F8FAFC" CornerRadius="12" Padding="18" BorderThickness="1" BorderBrush="#E2E8F0">
                                    <StackPanel>
                                        <TextBlock Text="Atalhos do INMETRO" FontWeight="SemiBold" Foreground="#475569" FontSize="12" Margin="0,0,14,12"/>

                                        <Button Style="{StaticResource LinkButtonStyle}" Tag="https://www.gov.br/inmetro/pt-br" Click="AbrirLink_Click" 
                                                Content="🌐 Portal Oficial gov.br/inmetro"/>

                                        <Button Style="{StaticResource LinkButtonStyle}" Tag="https://www.gov.br/inmetro/pt-br/acesso-a-informacao/perguntas-frequentes/acreditacao/organismos-de-sistemas-de-gestao-ambiental-oca" Click="AbrirLink_Click" 
                                                Content="🔍 Buscar Organismos (OCA)"/>

                                        <Button Style="{StaticResource LinkButtonStyle}" Tag="https://certifiq.inmetro.gov.br" Click="AbrirLink_Click" 
                                                Content="📋 Banco de dados Certifiq"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>