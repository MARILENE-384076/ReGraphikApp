<UserControl x:Class="ReGraphik.Views.Controls.EsgControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Background="#F8FAFC">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Proposta de Valor ESG"
                           FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Ambiental · Social · Governança — Guia de Certificação"
                           FontSize="13" Foreground="#64748B" Margin="0,4,0,0"/>
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    Command="{Binding ExportarPdfCommand}"
                    Height="40" Padding="18,0"
                    Background="#1649a2" Foreground="White"
                    FontWeight="SemiBold" BorderThickness="0"
                    Cursor="Hand" VerticalAlignment="Center">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⬇ " VerticalAlignment="Center"/>
                    <TextBlock Text="Exportar PDF" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Conteúdo rolável -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Card E — Ambiental -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.05" Color="#000"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#DCFCE7" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                                <TextBlock Text="E" FontSize="18" FontWeight="Bold" Foreground="#166534"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ambiental (Environmental)"
                                           FontSize="15" FontWeight="Bold" Foreground="#166534"/>
                                <TextBlock Text="Redução de impacto e circularidade de resíduos"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22"
                                   Text="O ReGraphik transforma resíduos gráficos — papel, cartão e vinil — em matéria-prima circular. Cada resíduo cadastrado deixa de ir ao aterro e passa a ter um destino sustentável, reduzindo emissões de CO₂ e custos de descarte."/>
                        <Border Background="#F0FDF4" CornerRadius="8" Padding="16,10" Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#166534"
                                       Text="📊  Indicadores: kg cadastrados · pontos de coleta homologados · estimativa de CO₂ evitado por tonelada reciclada."/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card S — Social -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.05" Color="#000"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#DBEAFE" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                                <TextBlock Text="S" FontSize="18" FontWeight="Bold" Foreground="#1D4ED8"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Social"
                                           FontSize="15" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Geração de valor para toda a cadeia produtiva"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22"
                                   Text="A plataforma conecta empresas gráficas a cooperativas, catadores e coletores, gerando renda e formalização para trabalhadores da reciclagem. O sistema de sugestões permite que resíduos se tornem produtos — camisetas, canecas, brindes — criando novos mercados e fortalecendo a economia circular local."/>
                        <Border Background="#EFF6FF" CornerRadius="8" Padding="16,10" Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1D4ED8"
                                       Text="🤝  Benefícios: geração de renda para catadores · fomento à economia circular · redução de custos operacionais para empresas parceiras."/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card G — Governança -->
                <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.05" Color="#000"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="#F3E8FF" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                                <TextBlock Text="G" FontSize="18" FontWeight="Bold" Foreground="#6B21A8"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Governança"
                                           FontSize="15" FontWeight="Bold" Foreground="#6B21A8"/>
                                <TextBlock Text="Rastreabilidade, conformidade e transparência"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22"
                                   Text="Cada resíduo registrado tem origem, tipo, quantidade, condição e destino final auditáveis. Isso permite demonstrar conformidade com a Política Nacional de Resíduos Sólidos (Lei 12.305/2010) e fortalecer a governança ambiental corporativa, facilitando auditorias, licitações e relatórios GRI ou CDP."/>
                        <Border Background="#FAF5FF" CornerRadius="8" Padding="16,10" Margin="0,14,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#6B21A8"
                                       Text="📋  Diferenciais: histórico auditável · relatórios exportáveis · dados para laudos e prestação de contas a órgãos reguladores."/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Card Certificação INMETRO -->
<Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,8">
    <Border.Effect>
        <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.05" Color="#000"/>
    </Border.Effect>
    <StackPanel>

        <!-- Cabeçalho do card -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border Background="#FEF3C7" CornerRadius="8" Padding="8,4" Margin="0,0,12,0">
                <TextBlock Text="🏅" FontSize="18"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Certificação Ambiental ISO 14001 via INMETRO"
                           FontSize="15" FontWeight="Bold" Foreground="#B45309"/>
                <TextBlock Text="Caminho oficial para empresas parceiras do ReGraphik"
                           FontSize="12" Foreground="#64748B"/>
            </StackPanel>
        </StackPanel>

        <!-- Texto introdutório -->
        <TextBlock TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="22"
                   Margin="0,0,0,20"
                   Text="O ReGraphik funciona como base documental para sua empresa iniciar o processo de certificação ambiental ISO 14001, reconhecida pelo INMETRO. O relatório gerado aqui comprova suas práticas de gestão de resíduos e pode ser apresentado ao organismo certificador durante a auditoria."/>

        <!-- Passos -->
        <StackPanel>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#FEF3C7" CornerRadius="13" Width="26" Height="26" HorizontalAlignment="Left">
                    <TextBlock Text="1" FontWeight="Bold" Foreground="#B45309" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"
                               Text="Gere o Relatório Comprobatório no ReGraphik"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"
                               Text="Acesse a aba Relatórios, gere o comprovante de movimentação de resíduos e exporte em PDF. Esse documento será sua evidência de uso da plataforma."/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="13" Width="26" Height="26" HorizontalAlignment="Left">
                    <TextBlock Text="2" FontWeight="Bold" Foreground="#1E40AF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"
                               Text="Acesse o site oficial do INMETRO"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"
                               Text="No portal do INMETRO, localize um Organismo de Certificação Ambiental (OCA) acreditado para conduzir a auditoria ISO 14001 na sua empresa."/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="13" Width="26" Height="26" HorizontalAlignment="Left">
                    <TextBlock Text="3" FontWeight="Bold" Foreground="#1E40AF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"
                               Text="Entre em contato com o OCA escolhido"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"
                               Text="Apresente o relatório do ReGraphik como evidência de gestão de resíduos. O OCA irá conduzir a análise documental e a auditoria presencial na sua empresa."/>
                </StackPanel>
            </Grid>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#DBEAFE" CornerRadius="13" Width="26" Height="26" HorizontalAlignment="Left">
                    <TextBlock Text="4" FontWeight="Bold" Foreground="#1E40AF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Foreground="#1E293B" FontSize="13"
                               Text="Receba o Certificado ISO 14001"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"
                               Text="Após a auditoria aprovada, o OCA emite o certificado e registra no sistema Certifiq do INMETRO. O certificado é válido por 3 anos com auditorias anuais de manutenção."/>
                </StackPanel>
            </Grid>

        </StackPanel>

        <!-- Links oficiais -->
        <Border Background="#FFFBEB" CornerRadius="8" Padding="16,14" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="🔗  Links oficiais" FontWeight="SemiBold"
                           Foreground="#B45309" FontSize="13" Margin="0,0,0,10"/>

                <Button Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,8"
                        Background="Transparent" BorderThickness="0"
                        Tag="https://www.gov.br/inmetro/pt-br"
                        Click="AbrirLink_Click">
                    <TextBlock FontSize="12" Foreground="#2563EB"
                               TextDecorations="Underline"
                               Text="🌐  Portal INMETRO — gov.br/inmetro"/>
                </Button>

                <Button Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,8"
                        Background="Transparent" BorderThickness="0"
                        Tag="https://www.gov.br/inmetro/pt-br/acesso-a-informacao/perguntas-frequentes/acreditacao/organismos-de-sistemas-de-gestao-ambiental-oca"
                        Click="AbrirLink_Click">
                    <TextBlock FontSize="12" Foreground="#2563EB"
                               TextDecorations="Underline"
                               Text="🔍  Buscar Organismo Certificador Ambiental (OCA) acreditado"/>
                </Button>

                <Button Cursor="Hand" HorizontalAlignment="Left"
                        Background="Transparent" BorderThickness="0"
                        Tag="https://certifiq.inmetro.gov.br"
                        Click="AbrirLink_Click">
                    <TextBlock FontSize="12" Foreground="#2563EB"
                               TextDecorations="Underline"
                               Text="📋  Certifiq — Consultar certificados ISO 14001 emitidos no Brasil"/>
                </Button>

            </StackPanel>
        </Border>

    </StackPanel>
</Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>