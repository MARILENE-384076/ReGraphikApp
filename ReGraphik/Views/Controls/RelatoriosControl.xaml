<UserControl x:Class="ReGraphik.Views.Controls.RelatoriosControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReGraphik.Views.Controls"
             xmlns:converters="clr-namespace:ReGraphik.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#F8FAFC">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0"
                   Text="Relatórios"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextoPadraoColor}"
                   Margin="0,0,0,16"/>

            <!-- Painel de Filtros -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Filtros" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextoPadraoColor}" Margin="0,0,0,14"/>

                    <!-- Tipo, Origem, Status -->
                    <Grid Grid.Row="1" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tipo de Material" Style="{StaticResource FilterLabelStyle}"/>
                            <Grid>
                                <ComboBox x:Name="CboTipoMaterial" Style="{StaticResource FilterComboBoxStyle}"
                                      SelectedValue="{Binding FiltroTipo, Mode=TwoWay}"
                                      SelectedValuePath="Content">
                                    <ComboBoxItem Content="Todos"/>
                                    <ComboBoxItem Content="Papel Offset"/>
                                    <ComboBoxItem Content="Papel Couché"/>
                                    <ComboBoxItem Content="Papel Kraft"/>
                                    <ComboBoxItem Content="Papelão"/>
                                    <ComboBoxItem Content="Adesivo Vinil"/>
                                    <ComboBoxItem Content="Lona"/>
                                    <ComboBoxItem Content="PVC"/>
                                    <ComboBoxItem Content="Acrílico"/>
                                    <ComboBoxItem Content="Outro"/>
                                </ComboBox>

                                <TextBlock Text="Selecione o tipo..." Foreground="{DynamicResource TextoCinzaColor}" IsHitTestVisible="False" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboTipoMaterial}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboTipoMaterial}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Origem" Style="{StaticResource FilterLabelStyle}"/>
                            <Grid>
                                <ComboBox x:Name="CboOrigem" Style="{StaticResource FilterComboBoxStyle}"
                                      SelectedValue="{Binding FiltroOrigem, Mode=TwoWay}"
                                      SelectedValuePath="Content">
                                    <ComboBoxItem Content="Todas"/>
                                    <ComboBoxItem Content="Restos de Corte"/>
                                    <ComboBoxItem Content="Sobra de Impressão"/>
                                </ComboBox>

                                <TextBlock Text="Selecione a origem..." Foreground="{DynamicResource TextoCinzaColor}" IsHitTestVisible="False" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboOrigem}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboOrigem}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Status" Style="{StaticResource FilterLabelStyle}"/>
                            <Grid>
                                <ComboBox x:Name="CboStatus" Style="{StaticResource FilterComboBoxStyle}"
                                      SelectedValue="{Binding FiltroStatus, Mode=TwoWay}"
                                      SelectedValuePath="Content">
                                    <ComboBoxItem Content="Todos"/>
                                    <ComboBoxItem Content="Em Estoque"/>
                                    <ComboBoxItem Content="Reaproveitado"/>
                                    <ComboBoxItem Content="Processado"/>
                                </ComboBox>

                                <TextBlock Text="Selecione o status..." Foreground="{DynamicResource TextoCinzaColor}" IsHitTestVisible="False" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboStatus}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=CboStatus}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Período + botões -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Data Início" Style="{StaticResource FilterLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DataInicio, Mode=TwoWay}"
                                    Style="{StaticResource ModernDatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Data Fim" Style="{StaticResource FilterLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding DataFim, Mode=TwoWay}"
                                    Style="{StaticResource ModernDatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4"/>

                        <Button Grid.Column="6" Content="Limpar"
                            Command="{Binding LimparFiltrosCommand}"
                            Width="90" Height="38"
                            Background="White" BorderBrush="{DynamicResource CinzaClaroColor}" BorderThickness="1"
                            Foreground="{DynamicResource CinzaColor}" FontWeight="SemiBold" VerticalAlignment="Bottom">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="8" Content="Gerar Relatório"
                            Command="{Binding GerarRelatorioCommand}"
                            Width="140" Height="38"
                            Background="{DynamicResource AzulMedioColor}" BorderThickness="0"
                            Foreground="White" FontWeight="SemiBold" VerticalAlignment="Bottom">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- Cards de Resumo -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource AzulEscuroColor}" CornerRadius="12" Padding="20" Height="100" Margin="0,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalResiduos}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Total de descartes registrados" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{DynamicResource AzulMedioColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding PesoTotal, StringFormat={}{0:N2} kg}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Peso acumulado de resíduos" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource AzulClaroColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,12,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Reaproveitados}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Total de materiais reciclados" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{DynamicResource AzulMuitoClaroColor}" CornerRadius="12" Padding="20" Height="100" Margin="12,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ValorEconomico}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Valor economizado" FontSize="14" Foreground="White" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>


            <!-- Tabela de Resultados -->
            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.04" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Cabeçalho da tabela -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Resultado do Relatório"
                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextoPadraoColor}" VerticalAlignment="Center"/>
                            <Border Background="#EFF6FF" CornerRadius="10" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalRegistros, StringFormat={}{0} registro(s)}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#1E40AF"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding MensagemStatus}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextoCinzaColor}" Margin="0,0,12,0"/>

                            <Button Content="⬇ Exportar PDF"
                                Command="{Binding ExportarPdfCommand}"
                                IsEnabled="{Binding PodeExportar}"
                                Width="130" Height="36"
                                Background="White"
                                BorderBrush="{DynamicResource AzulMedioColor}" BorderThickness="1"
                                Foreground="{DynamicResource AzulMedioColor}" FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ResiduosFiltrados}"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          RowHeight="48" IsReadOnly="True" HeadersVisibility="Column">

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1E293B"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1E293B"/>
                                </Style.Resources>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#1E40AF"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="0.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CinzaColor}"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Material" Binding="{Binding TipoResiduo}" Width="1.5*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextoPadraoColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Origem" Binding="{Binding Origem}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Projeto" Binding="{Binding Projeto}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Quantidade (kg)" Binding="{Binding Quantidade}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="TextAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextoPadraoColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Condição" Binding="{Binding Condicao}" Width="2.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="#334155"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Data" Binding="{Binding DataCadastro, StringFormat=\{0:dd/MM/yyyy\}}" Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Foreground" Value="{DynamicResource CinzaColor}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                    CornerRadius="12" Padding="10,4"
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" Foreground="#FFFFFF"
                           FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
