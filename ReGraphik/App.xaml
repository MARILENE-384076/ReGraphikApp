<Application x:Class="ReGraphik.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ReGraphik">

    <!-- Recursos da Aplicação -->
    <Application.Resources>
        <ResourceDictionary>
            <!-- Recursos Merged -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/Cores.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Styles/Textos.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Styles/Inputs.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/Styles/Botoes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>